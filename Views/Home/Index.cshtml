@model Factors.Web.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "داشبورد";
}

<div class="page-header">
    <h4><i class="bi bi-speedometer2"></i> داشبورد</h4>
    <span class="text-muted small"><i class="bi bi-clock"></i> @Factors.Web.Models.Entities.PersianDateService.Now</span>
</div>

<!-- Main Stats Cards -->
<div class="row g-3 mb-3">
    <div class="col-xl-2 col-md-4 col-sm-6">
        <div class="card stat-card-compact border-0">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="stat-label-sm">فاکتورها</div>
                        <div class="stat-value-sm text-primary">@Model.TotalFactors.ToString("N0")</div>
                    </div>
                    <div class="stat-icon-sm icon-badge icon-badge-blue">
                        <i class="bi bi-receipt-cutoff"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-sm-6">
        <div class="card stat-card-compact border-0">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="stat-label-sm">فروش کل (ریال)</div>
                        <div class="stat-value-sm text-success">@(Model.TotalSalesAmount >= 1000000 ? (Model.TotalSalesAmount / 1000000).ToString("N1") + "M" : Model.TotalSalesAmount.ToString("N0"))</div>
                    </div>
                    <div class="stat-icon-sm icon-badge icon-badge-teal">
                        <i class="bi bi-currency-exchange"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-sm-6">
        <div class="card stat-card-compact border-0">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="stat-label-sm">محصولات</div>
                        <div class="stat-value-sm text-info">@Model.TotalProducts.ToString("N0")</div>
                    </div>
                    <div class="stat-icon-sm icon-badge icon-badge-purple">
                        <i class="bi bi-box"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-sm-6">
        <div class="card stat-card-compact border-0">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="stat-label-sm">مشتریان</div>
                        <div class="stat-value-sm text-warning">@Model.TotalPersons.ToString("N0")</div>
                    </div>
                    <div class="stat-icon-sm icon-badge icon-badge-orange">
                        <i class="bi bi-people"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-sm-6">
        <div class="card stat-card-compact border-0">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="stat-label-sm">دسته‌بندی‌ها</div>
                        <div class="stat-value-sm" style="color:#e71d36">@Model.TotalCategories.ToString("N0")</div>
                    </div>
                    <div class="stat-icon-sm icon-badge icon-badge-red">
                        <i class="bi bi-folder"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-sm-6">
        <div class="card stat-card-compact border-0">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="stat-label-sm">کاربران سیستم</div>
                        <div class="stat-value-sm" style="color:#7c3aed">@Model.TotalUsers.ToString("N0")</div>
                    </div>
                    <div class="stat-icon-sm icon-badge icon-badge-pink">
                        <i class="bi bi-person-gear"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-3 mb-3">
    <!-- Monthly Sales Chart -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header-compact">
                <span class="icon-badge icon-badge-blue"><i class="bi bi-graph-up"></i></span>
                <span class="header-title">روند فروش ماهانه</span>
            </div>
            <div class="card-body p-3">
                <div style="position:relative;height:280px;">
                    <canvas id="monthlySalesChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Category Distribution -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header-compact">
                <span class="icon-badge icon-badge-teal"><i class="bi bi-pie-chart"></i></span>
                <span class="header-title">فروش بر اساس دسته‌بندی</span>
            </div>
            <div class="card-body p-3">
                <div style="position:relative;height:280px;">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Daily Sales + Customer Type -->
<div class="row g-3 mb-3">
    <!-- Daily Sales (Last 30 days) -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header-compact">
                <span class="icon-badge icon-badge-orange"><i class="bi bi-calendar3"></i></span>
                <span class="header-title">فروش روزانه (۳۰ روز اخیر)</span>
            </div>
            <div class="card-body p-3">
                <div style="position:relative;height:220px;">
                    <canvas id="dailySalesChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Customer Type Distribution -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header-compact">
                <span class="icon-badge icon-badge-purple"><i class="bi bi-people"></i></span>
                <span class="header-title">ترکیب مشتریان</span>
            </div>
            <div class="card-body d-flex flex-column justify-content-center p-3">
                <div style="position:relative;height:180px;">
                    <canvas id="personTypeChart"></canvas>
                </div>
                <div class="d-flex justify-content-center gap-4 mt-2">
                    @if (Model.PersonTypeDistribution.Any())
                    {
                        foreach (var pt in Model.PersonTypeDistribution)
                        {
                            <div class="text-center">
                                <strong class="@(pt.IsIndividual ? "text-primary" : "text-success")">@pt.Count</strong>
                                <div class="text-muted small">@pt.TypeName</div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Factors + Top Products + Top Customers -->
<div class="row g-3">
    <!-- Recent Factors -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header-compact">
                <span class="icon-badge icon-badge-blue"><i class="bi bi-clock-history"></i></span>
                <span class="header-title">آخرین فاکتورها</span>
                <a asp-controller="Factor" asp-action="Index" class="btn btn-sm btn-outline-primary me-auto" style="font-size:0.72rem">مشاهده همه</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0" style="font-size:0.82rem">
                        <thead>
                            <tr>
                                <th style="font-size:0.75rem">شماره</th>
                                <th style="font-size:0.75rem">مشتری</th>
                                <th style="font-size:0.75rem">تاریخ</th>
                                <th style="font-size:0.75rem">مبلغ</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentFactors.Any())
                            {
                                foreach (var factor in Model.RecentFactors)
                                {
                                    <tr>
                                        <td><strong>@factor.Id</strong></td>
                                        <td>@factor.PersonName</td>
                                        <td><small class="text-muted">@factor.PersianCreateDate</small></td>
                                        <td><span class="text-success fw-bold">@(factor.TotalAmount >= 1000000 ? (factor.TotalAmount / 1000000).ToString("N1") + "M" : factor.TotalAmount.ToString("N0"))</span></td>
                                        <td>
                                            <a asp-controller="Factor" asp-action="Details" asp-route-id="@factor.Id" class="btn btn-sm btn-outline-info py-0 px-1" style="font-size:0.72rem">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="5" class="text-center text-muted py-3" style="font-size:0.85rem">فاکتوری ثبت نشده است</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Products -->
    <div class="col-lg-3">
        <div class="card border-0 shadow-sm">
            <div class="card-header-compact">
                <span class="icon-badge icon-badge-orange"><i class="bi bi-trophy"></i></span>
                <span class="header-title">پرفروش‌ها</span>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    @if (Model.TopProducts.Any())
                    {
                        var rank = 1;
                        foreach (var product in Model.TopProducts)
                        {
                            var rankColors = new[] { "warning", "secondary", "danger" };
                            var rankColor = rank <= 3 ? rankColors[rank - 1] : "light";
                            <div class="list-group-item d-flex justify-content-between align-items-center py-2 px-3" style="font-size:0.8rem">
                                <div class="d-flex align-items-center">
                                    <span class="badge bg-@rankColor me-2 rounded-pill" style="min-width:22px;font-size:0.65rem">@rank</span>
                                    <div>
                                        <div class="fw-semibold" style="font-size:0.8rem">@product.ProductName</div>
                                        <small class="text-muted" style="font-size:0.68rem">تعداد: @product.TotalQty</small>
                                    </div>
                                </div>
                                <span class="badge bg-primary rounded-pill" style="font-size:0.65rem">@((product.TotalAmount / 1000000).ToString("N1"))M</span>
                            </div>
                            rank++;
                        }
                    }
                    else
                    {
                        <div class="list-group-item text-center text-muted py-3" style="font-size:0.85rem">داده‌ای موجود نیست</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Top Customers -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header-compact">
                <span class="icon-badge icon-badge-teal"><i class="bi bi-star"></i></span>
                <span class="header-title">بهترین مشتریان</span>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    @if (Model.TopCustomers.Any())
                    {
                        var rank = 1;
                        foreach (var customer in Model.TopCustomers)
                        {
                            var rankColors = new[] { "warning", "secondary", "danger" };
                            var rankColor = rank <= 3 ? rankColors[rank - 1] : "light";
                            <div class="list-group-item d-flex justify-content-between align-items-center py-2 px-3" style="font-size:0.8rem">
                                <div class="d-flex align-items-center">
                                    <span class="badge bg-@rankColor me-2 rounded-pill" style="min-width:22px;font-size:0.65rem">@rank</span>
                                    <div>
                                        <div class="fw-semibold" style="font-size:0.8rem">@customer.PersonName</div>
                                        <small class="text-muted" style="font-size:0.68rem">@customer.FactorCount فاکتور</small>
                                    </div>
                                </div>
                                <span class="badge bg-success rounded-pill" style="font-size:0.65rem">@((customer.TotalPurchase / 1000000).ToString("N1"))M</span>
                            </div>
                            rank++;
                        }
                    }
                    else
                    {
                        <div class="list-group-item text-center text-muted py-3" style="font-size:0.85rem">داده‌ای موجود نیست</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@{
    var jsonOpt = new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase };
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
    // Chart.js Global Config
    Chart.defaults.font.family = 'Vazirmatn, Segoe UI, Tahoma, sans-serif';
    Chart.defaults.direction = 'rtl';

    // Monthly Sales Chart
    var monthlyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlySales, jsonOpt));
    new Chart(document.getElementById('monthlySalesChart'), {
        type: 'bar',
        data: {
            labels: monthlyData.map(d => d.month),
            datasets: [
                {
                    label: 'مبلغ فروش (M)',
                    data: monthlyData.map(d => (d.totalAmount / 1000000).toFixed(1)),
                    backgroundColor: 'rgba(67, 97, 238, 0.3)',
                    borderColor: '#4361ee',
                    borderWidth: 2,
                    borderRadius: 6,
                    yAxisID: 'y'
                },
                {
                    label: 'تعداد فاکتور',
                    data: monthlyData.map(d => d.factorCount),
                    type: 'line',
                    borderColor: '#2ec4b6',
                    backgroundColor: 'rgba(46, 196, 182, 0.1)',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    yAxisID: 'y1'
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: { position: 'top', labels: { usePointStyle: true, padding: 12 } },
                tooltip: { rtl: true }
            },
            scales: {
                x: { grid: { display: false }, ticks: { font: { size: 11 } } },
                y: {
                    position: 'left',
                    grid: { color: 'rgba(0,0,0,0.04)' },
                    ticks: { font: { size: 11 }, callback: v => v + 'M' }
                },
                y1: {
                    position: 'right',
                    grid: { display: false },
                    ticks: { font: { size: 11 } }
                }
            }
        }
    });

    // Category Chart
    var categoryData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CategorySales, jsonOpt));
    var catColors = ['#4361ee', '#2ec4b6', '#ff9f1c', '#e71d36', '#7c3aed', '#ec4899', '#3a86ff', '#0ead8c'];
    new Chart(document.getElementById('categoryChart'), {
        type: 'doughnut',
        data: {
            labels: categoryData.map(d => d.categoryName),
            datasets: [{
                data: categoryData.map(d => (d.totalAmount / 1000000).toFixed(1)),
                backgroundColor: catColors.slice(0, categoryData.length),
                borderWidth: 2,
                borderColor: '#fff'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom', labels: { usePointStyle: true, padding: 10, font: { size: 11 } } },
                tooltip: {
                    rtl: true,
                    callbacks: { label: ctx => ctx.label + ': ' + ctx.raw + 'M' }
                }
            }
        }
    });

    // Daily Sales Chart
    var dailyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailySales, jsonOpt));
    new Chart(document.getElementById('dailySalesChart'), {
        type: 'line',
        data: {
            labels: dailyData.map(d => d.persianDate),
            datasets: [{
                label: 'فروش روزانه (M)',
                data: dailyData.map(d => (d.totalAmount / 1000000).toFixed(1)),
                borderColor: '#ff9f1c',
                backgroundColor: 'rgba(255, 159, 28, 0.1)',
                borderWidth: 2,
                fill: true,
                tension: 0.4,
                pointRadius: 2,
                pointHoverRadius: 5
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: { rtl: true }
            },
            scales: {
                x: {
                    grid: { display: false },
                    ticks: { font: { size: 9 }, maxRotation: 45, maxTicksLimit: 15 }
                },
                y: {
                    grid: { color: 'rgba(0,0,0,0.04)' },
                    ticks: { font: { size: 10 }, callback: v => v + 'M' }
                }
            }
        }
    });

    // Person Type Chart
    var personTypeData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PersonTypeDistribution, jsonOpt));
    new Chart(document.getElementById('personTypeChart'), {
        type: 'doughnut',
        data: {
            labels: personTypeData.map(d => d.isIndividual ? 'حقیقی' : 'حقوقی'),
            datasets: [{
                data: personTypeData.map(d => d.count),
                backgroundColor: ['#4361ee', '#2ec4b6'],
                borderWidth: 2,
                borderColor: '#fff'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '65%',
            plugins: {
                legend: { position: 'bottom', labels: { usePointStyle: true, padding: 8, font: { size: 11 } } },
                tooltip: { rtl: true }
            }
        }
    });
</script>
}
