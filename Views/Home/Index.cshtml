@model Factors.Web.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "داشبورد";
}

<div class="page-header">
    <h4><i class="bi bi-speedometer2"></i> داشبورد</h4>
</div>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="stat-label">تعداد فاکتورها</div>
                        <div class="stat-value text-primary">@Model.TotalFactors</div>
                    </div>
                    <div class="stat-icon" style="background:#eef0ff;color:#4361ee;">
                        <i class="bi bi-receipt-cutoff"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="stat-label">فروش کل (ریال)</div>
                        <div class="stat-value text-success">@Model.TotalSalesAmount.ToString("N0")</div>
                    </div>
                    <div class="stat-icon" style="background:#e6faf7;color:#2ec4b6;">
                        <i class="bi bi-currency-exchange"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="stat-label">تعداد محصولات</div>
                        <div class="stat-value text-info">@Model.TotalProducts</div>
                    </div>
                    <div class="stat-icon" style="background:#e8f0fe;color:#3a86ff;">
                        <i class="bi bi-box"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="stat-label">تعداد مشتریان</div>
                        <div class="stat-value text-warning">@Model.TotalPersons</div>
                    </div>
                    <div class="stat-icon" style="background:#fff7e6;color:#ff9f1c;">
                        <i class="bi bi-people"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Secondary Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-sm-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-3">
                <i class="bi bi-folder text-primary" style="font-size: 1.5rem;"></i>
                <div class="mt-1"><small class="text-muted">دسته‌بندی‌ها</small></div>
                <strong class="fs-5">@Model.TotalCategories</strong>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-3">
                <i class="bi bi-box-seam text-success" style="font-size: 1.5rem;"></i>
                <div class="mt-1"><small class="text-muted">بسته‌ها</small></div>
                <strong class="fs-5">@Model.TotalPacks</strong>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-3">
                <i class="bi bi-person-gear text-info" style="font-size: 1.5rem;"></i>
                <div class="mt-1"><small class="text-muted">کاربران</small></div>
                <strong class="fs-5">@Model.TotalUsers</strong>
            </div>
        </div>
    </div>
</div>

<!-- Recent Factors + Top Products -->
<div class="row g-3">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold"><i class="bi bi-clock-history text-primary"></i> آخرین فاکتورها</h6>
                <a asp-controller="Factor" asp-action="Index" class="btn btn-sm btn-outline-primary">مشاهده همه</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>شماره</th>
                                <th>مشتری</th>
                                <th>تاریخ</th>
                                <th>آیتم</th>
                                <th>مبلغ کل</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentFactors.Any())
                            {
                                foreach (var factor in Model.RecentFactors)
                                {
                                    <tr>
                                        <td><strong>@factor.Id</strong></td>
                                        <td>@factor.PersonName</td>
                                        <td><small class="text-muted">@factor.PersianCreateDate</small></td>
                                        <td><span class="badge bg-light text-dark">@factor.TotalItems</span></td>
                                        <td><span class="text-success fw-bold">@factor.TotalAmount.ToString("N0")</span></td>
                                        <td>
                                            <a asp-controller="Factor" asp-action="Details" asp-route-id="@factor.Id" class="btn btn-sm btn-outline-info">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="6" class="text-center text-muted py-4">فاکتوری ثبت نشده است</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Products -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h6 class="mb-0 fw-bold"><i class="bi bi-trophy text-warning"></i> پرفروش‌ترین محصولات</h6>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    @if (Model.TopProducts.Any())
                    {
                        var rank = 1;
                        foreach (var product in Model.TopProducts)
                        {
                            var rankColors = new[] { "warning", "secondary", "danger" };
                            var rankColor = rank <= 3 ? rankColors[rank - 1] : "light";
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <span class="badge bg-@rankColor me-2 rounded-pill" style="min-width:28px">@rank</span>
                                    <div>
                                        <div class="fw-bold small">@product.ProductName</div>
                                        <small class="text-muted">تعداد: @product.TotalQty</small>
                                    </div>
                                </div>
                                <span class="badge bg-primary rounded-pill">@product.TotalAmount.ToString("N0")</span>
                            </div>
                            rank++;
                        }
                    }
                    else
                    {
                        <div class="list-group-item text-center text-muted py-4">داده‌ای موجود نیست</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
