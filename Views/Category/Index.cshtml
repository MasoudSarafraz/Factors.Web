@model Factors.Web.Models.ViewModels.CategoryListViewModel
@{
    ViewData["Title"] = "دسته‌بندی‌ها";
}

<div class="page-header">
    <h4><span class="icon-badge icon-badge-blue"><i class="bi bi-folder"></i></span> دسته‌بندی‌ها</h4>
    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createModal">
        <i class="bi bi-plus-lg"></i> دسته‌بندی جدید
    </button>
</div>

<!-- Search -->
<div class="search-bar">
    <form asp-action="Index" method="get">
        <div class="row g-2 align-items-center">
            <div class="col-md-6">
                <div class="input-group input-group-sm">
                    <input type="text" name="search" value="@Model.SearchTerm" class="form-control form-control-sm" placeholder="جستجو در دسته‌بندی‌ها..." />
                    <button class="btn btn-outline-primary btn-sm" type="submit"><i class="bi bi-search"></i></button>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Categories Table -->
<div class="card border-0 shadow-sm rounded-3">
    <div class="card-header-compact">
        <span class="icon-badge icon-badge-blue"><i class="bi bi-folder"></i></span>
        <span class="header-title">لیست دسته‌بندی‌ها</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 table-compact">
                <thead class="table-light">
                    <tr>
                        <th style="width:50px">#</th>
                        <th>نام دسته‌بندی</th>
                        <th>تعداد محصولات</th>
                        <th>تاریخ ایجاد</th>
                        <th style="width:150px">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Categories.Any())
                    {
                        int row = 1;
                        foreach (var item in Model.Categories)
                        {
                            <tr id="row-@item.Id">
                                <td>@row</td>
                                <td>@item.Name</td>
                                <td><span class="badge bg-info">@item.ProductCount</span></td>
                                <td>@item.PersianCreateDate</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-warning" onclick="editCategory(@item.Id, '@item.Name')" title="ویرایش">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('آیا از حذف این دسته‌بندی مطمئن هستید؟')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="حذف">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                            row++;
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center text-muted py-4">دسته‌بندی‌ای یافت نشد</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                <div class="modal-header-compact">
                    <h5 class="modal-title"><span class="icon-badge icon-badge-sm icon-badge-blue"><i class="bi bi-plus-circle"></i></span> دسته‌بندی جدید</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body-compact">
                    <div class="mb-2">
                        <label class="form-label-compact">نام دسته‌بندی</label>
                        <input type="text" name="Name" class="form-control form-control-sm" required maxlength="100" />
                    </div>
                </div>
                <div class="modal-footer-compact">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">انصراف</button>
                    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-check-lg"></i> ثبت</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Edit" method="post">
                <div class="modal-header-compact">
                    <h5 class="modal-title"><span class="icon-badge icon-badge-sm icon-badge-orange"><i class="bi bi-pencil"></i></span> ویرایش دسته‌بندی</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body-compact">
                    <input type="hidden" name="Id" id="editId" />
                    <div class="mb-2">
                        <label class="form-label-compact">نام دسته‌بندی</label>
                        <input type="text" name="Name" id="editName" class="form-control form-control-sm" required maxlength="100" />
                    </div>
                </div>
                <div class="modal-footer-compact">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">انصراف</button>
                    <button type="submit" class="btn btn-warning btn-sm"><i class="bi bi-check-lg"></i> ویرایش</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function editCategory(id, name) {
        $('#editId').val(id);
        $('#editName').val(name);
        new bootstrap.Modal($('#editModal')).show();
    }
</script>
}
