@model Factors.Web.Models.ViewModels.PersonListViewModel
@{
    ViewData["Title"] = "اشخاص";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0"><i class="bi bi-people"></i> اشخاص</h4>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">
        <i class="bi bi-plus-lg"></i> شخص جدید
    </button>
</div>

<!-- Search -->
<form asp-action="Index" method="get" class="mb-3">
    <div class="row g-2">
        <div class="col-md-6">
            <div class="input-group">
                <input type="text" name="search" value="@Model.SearchTerm" class="form-control" placeholder="جستجو در اشخاص..." />
                <button class="btn btn-outline-primary" type="submit"><i class="bi bi-search"></i></button>
            </div>
        </div>
    </div>
</form>

<!-- Persons Table -->
<div class="card border-0 shadow-sm rounded-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:50px">#</th>
                        <th>نام</th>
                        <th>نوع</th>
                        <th>تعداد فاکتور</th>
                        <th>تاریخ ایجاد</th>
                        <th style="width:150px">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Persons.Any())
                    {
                        int row = 1;
                        foreach (var item in Model.Persons)
                        {
                            <tr>
                                <td>@row</td>
                                <td>@item.PersonName</td>
                                <td>
                                    @if (item.IsIndividual)
                                    {
                                        <span class="badge bg-info">حقیقی</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">حقوقی</span>
                                    }
                                </td>
                                <td><span class="badge bg-primary">@item.FactorCount</span></td>
                                <td>@item.PersianCreateDate</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-warning" onclick="editPerson(@item.Id)" title="ویرایش">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('آیا از حذف این شخص مطمئن هستید؟')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="حذف"><i class="bi bi-trash"></i></button>
                                        </form>
                                    }
                                </td>
                            </tr>
                            row++;
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4">شخصی یافت نشد</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-plus-circle"></i> شخص جدید</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">نام</label>
                        <input type="text" name="PersonName" class="form-control" required maxlength="150" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">نوع شخص</label>
                        <select name="IsIndividual" class="form-select">
                            <option value="true">حقیقی</option>
                            <option value="false">حقوقی</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">انصراف</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> ثبت</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Edit" method="post">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title"><i class="bi bi-pencil"></i> ویرایش شخص</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="Id" id="editId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">نام</label>
                        <input type="text" name="PersonName" id="editPersonName" class="form-control" required maxlength="150" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">نوع شخص</label>
                        <select name="IsIndividual" id="editIsIndividual" class="form-select">
                            <option value="true">حقیقی</option>
                            <option value="false">حقوقی</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">انصراف</button>
                    <button type="submit" class="btn btn-warning"><i class="bi bi-check-lg"></i> ویرایش</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function editPerson(id) {
        $.get('/Person/GetById/' + id, function(data) {
            $('#editId').val(data.id);
            $('#editPersonName').val(data.personName);
            $('#editIsIndividual').val(data.isIndividual.toString());
            new bootstrap.Modal($('#editModal')).show();
        });
    }
</script>
}
