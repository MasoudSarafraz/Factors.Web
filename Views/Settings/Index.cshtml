@model Factors.Web.Models.ViewModels.SettingsViewModel
@{
    ViewData["Title"] = "تنظیمات سیستم";
}

<div class="page-header">
    <h4><i class="bi bi-gear"></i> تنظیمات سیستم</h4>
</div>

<form asp-action="Index" method="post" id="settingsForm">
    @Html.AntiForgeryToken()

    <div class="row g-3">
        <!-- Company Info -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white d-flex align-items-center gap-2 py-2 px-3">
                    <span class="d-inline-flex align-items-center justify-content-center" style="width:28px;height:28px;border-radius:7px;background:linear-gradient(135deg,#4361ee,#3a86ff);color:#fff;font-size:0.85rem;">
                        <i class="bi bi-building"></i>
                    </span>
                    <span class="fw-bold" style="font-size:0.9rem;">اطلاعات شرکت</span>
                </div>
                <div class="card-body p-3">
                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label mb-1" style="font-size:0.8rem;">نام شرکت</label>
                            <input type="text" name="CompanyName" value="@Model.CompanyName" class="form-control form-control-sm" placeholder="نام شرکت یا سازمان" />
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label mb-1" style="font-size:0.8rem;">شماره تلفن</label>
                            <input type="text" name="CompanyPhone" value="@Model.CompanyPhone" class="form-control form-control-sm" placeholder="021-12345678" />
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label mb-1" style="font-size:0.8rem;">کد اقتصادی</label>
                            <input type="text" name="CompanyEconomicCode" value="@Model.CompanyEconomicCode" class="form-control form-control-sm" placeholder="کد اقتصادی" />
                        </div>
                        <div class="col-12">
                            <label class="form-label mb-1" style="font-size:0.8rem;">آدرس</label>
                            <input type="text" name="CompanyAddress" value="@Model.CompanyAddress" class="form-control form-control-sm" placeholder="آدرس شرکت" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Print Template Settings -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white d-flex align-items-center gap-2 py-2 px-3">
                    <span class="d-inline-flex align-items-center justify-content-center" style="width:28px;height:28px;border-radius:7px;background:linear-gradient(135deg,#2ec4b6,#0ead8c);color:#fff;font-size:0.85rem;">
                        <i class="bi bi-printer"></i>
                    </span>
                    <span class="fw-bold" style="font-size:0.9rem;">تنظیمات چاپ فاکتور</span>
                </div>
                <div class="card-body p-3">
                    <div class="mb-2">
                        <label class="form-label mb-1" style="font-size:0.8rem;">قالب پیش‌فرض چاپ</label>
                        <select name="DefaultFactorPrintTemplateId" class="form-select form-select-sm" id="templateSelect">
                            <option value="">قالب پیش‌فرض PDF</option>
                            @foreach (var template in Model.ReportTemplates)
                            {
                                <option value="@template.Id" selected="@(Model.DefaultFactorPrintTemplateId == template.Id)">
                                    @template.Name — @template.TemplateTypeName
                                </option>
                            }
                        </select>
                        <div class="form-text mt-1" style="font-size:0.75rem;">
                            <i class="bi bi-info-circle"></i>
                            با انتخاب قالب Word، دکمه «چاپ» از آن قالب استفاده می‌کند.
                        </div>
                    </div>

                    @if (Model.ReportTemplates.Any())
                    {
                        <div class="mt-2">
                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <span class="text-muted" style="font-size:0.75rem;font-weight:600;">قالب‌های موجود</span>
                                <span class="badge bg-light text-dark" style="font-size:0.7rem;">@Model.ReportTemplates.Count قالب</span>
                            </div>
                            <div class="list-group list-group-flush" style="font-size:0.82rem;">
                                @foreach (var template in Model.ReportTemplates)
                                {
                                    var isActive = Model.DefaultFactorPrintTemplateId == template.Id;
                                    <label class="list-group-item list-group-item-action d-flex align-items-center justify-content-between px-2 py-1_5 cursor-pointer @(isActive ? "border-end-3" : "")" style="border-right-width:3px;@(isActive ? "border-right-color:#2ec4b6;background:#f0fdf9;" : "")">
                                        <div class="d-flex align-items-center gap-2">
                                            <input type="radio" name="DefaultFactorPrintTemplateId" value="@template.Id" class="form-check-input m-0" style="font-size:0.8rem;" @(isActive ? "checked" : "") />
                                            <span>@template.Name</span>
                                        </div>
                                        <div class="d-flex align-items-center gap-1">
                                            <span class="badge" style="background:#e8f4fd;color:#1a73e8;font-size:0.7rem;">@template.TemplateTypeName</span>
                                            @if (isActive)
                                            {
                                                <span class="badge" style="background:#e6f9f0;color:#0ead8c;font-size:0.7rem;"><i class="bi bi-check-circle-fill"></i></span>
                                            }
                                        </div>
                                    </label>
                                }
                                <label class="list-group-item list-group-item-action d-flex align-items-center gap-2 px-2 py-1_5 cursor-pointer @(!Model.DefaultFactorPrintTemplateId.HasValue ? "border-end-3" : "")" style="border-right-width:3px;@(!Model.DefaultFactorPrintTemplateId.HasValue ? "border-right-color:#2ec4b6;background:#f0fdf9;" : "")">
                                    <input type="radio" name="DefaultFactorPrintTemplateId" value="" class="form-check-input m-0" style="font-size:0.8rem;" @(!Model.DefaultFactorPrintTemplateId.HasValue ? "checked" : "") />
                                    <span>قالب پیش‌فرض PDF</span>
                                    @if (!Model.DefaultFactorPrintTemplateId.HasValue)
                                    {
                                        <span class="badge" style="background:#e6f9f0;color:#0ead8c;font-size:0.7rem;"><i class="bi bi-check-circle-fill"></i></span>
                                    }
                                </label>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-3" style="font-size:0.82rem;">
                            <i class="bi bi-file-earmark-word text-muted" style="font-size:1.5rem;"></i>
                            <p class="text-muted mt-1 mb-1">هنوز قالبی تعریف نشده</p>
                            <a asp-controller="ReportTemplate" asp-action="Index" class="text-decoration-none" style="font-size:0.78rem;">
                                <i class="bi bi-plus-circle"></i> افزودن قالب
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Save Bar -->
    <div class="d-flex gap-2 mt-3">
        <button type="submit" class="btn btn-primary btn-sm px-4">
            <i class="bi bi-check-lg"></i> ذخیره تنظیمات
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-counterclockwise"></i> بازنشانی
        </a>
    </div>
</form>

<style>
    .py-1_5 {
        padding-top: 0.45rem;
        padding-bottom: 0.45rem;
    }
    .cursor-pointer {
        cursor: pointer;
    }
    .list-group-flush .list-group-item {
        border-left: none;
        border-right: none;
        transition: background 0.15s;
    }
    .list-group-flush .list-group-item:hover {
        background: #f8fafc;
    }
    .list-group-flush .list-group-item:first-child {
        border-top: none;
    }
    /* Sync radio buttons with select dropdown */
    .list-group input[type="radio"]:checked + span {
        font-weight: 600;
    }
    /* Hide the select dropdown when radio list is shown */
    #templateSelect {
        display: none;
    }
</style>

@section Scripts {
<script>
    // Sync radio button changes to hidden select for form submission
    document.querySelectorAll('.list-group input[type="radio"]').forEach(function(radio) {
        radio.addEventListener('change', function() {
            document.getElementById('templateSelect').value = this.value;
            // Update visual states
            document.querySelectorAll('.list-group .list-group-item').forEach(function(item) {
                item.style.borderRightColor = '';
                item.style.background = '';
                var badge = item.querySelector('.badge:last-child');
                // Remove active styling
            });
            // Style the parent label
            var parentLabel = this.closest('.list-group-item');
            if (parentLabel) {
                parentLabel.style.borderRightColor = '#2ec4b6';
                parentLabel.style.background = '#f0fdf9';
            }
        });
    });
</script>
}
