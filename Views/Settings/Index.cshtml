@model Factors.Web.Models.ViewModels.SettingsViewModel
@{
    ViewData["Title"] = "تنظیمات سیستم";
}

<div class="page-header">
    <h4><i class="bi bi-gear"></i> تنظیمات سیستم</h4>
</div>

<form asp-action="Index" method="post">
    @Html.AntiForgeryToken()

    <!-- Company Info -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-primary text-white">
            <h6 class="mb-0"><i class="bi bi-building"></i> اطلاعات شرکت</h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">نام شرکت</label>
                    <input type="text" name="CompanyName" value="@Model.CompanyName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">شماره تلفن</label>
                    <input type="text" name="CompanyPhone" value="@Model.CompanyPhone" class="form-control" placeholder="مثال: 021-12345678" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">آدرس</label>
                    <input type="text" name="CompanyAddress" value="@Model.CompanyAddress" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">کد اقتصادی</label>
                    <input type="text" name="CompanyEconomicCode" value="@Model.CompanyEconomicCode" class="form-control" />
                </div>
            </div>
        </div>
    </div>

    <!-- Print Settings -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-success text-white">
            <h6 class="mb-0"><i class="bi bi-printer"></i> تنظیمات چاپ فاکتور</h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label">قالب پیش‌فرض چاپ فاکتور</label>
                    <select name="DefaultFactorPrintTemplateId" class="form-select">
                        <option value="">— استفاده از قالب پیش‌فرض PDF —</option>
                        @foreach (var template in Model.ReportTemplates)
                        {
                            <option value="@template.Id" selected="@(Model.DefaultFactorPrintTemplateId == template.Id)">
                                @template.Name (@template.TemplateTypeName)
                            </option>
                        }
                    </select>
                    <div class="form-text">
                        اگر قالبی انتخاب کنید، دکمه «چاپ PDF» در صفحه فاکتور از آن قالب (Word/سفارشی) استفاده خواهد کرد.
                        در غیر این صورت از قالب PDF پیش‌فرض سیستم استفاده می‌شود.
                    </div>
                </div>
            </div>

            @if (Model.ReportTemplates.Any())
            {
                <div class="mt-3">
                    <label class="form-label small fw-bold text-muted">قالب‌های موجود:</label>
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>نام قالب</th>
                                    <th>نوع</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var template in Model.ReportTemplates)
                                {
                                    <tr class="@(Model.DefaultFactorPrintTemplateId == template.Id ? "table-success" : "")">
                                        <td>@template.Name</td>
                                        <td><span class="badge bg-info">@template.TemplateTypeName</span></td>
                                        <td>
                                            @if (Model.DefaultFactorPrintTemplateId == template.Id)
                                            {
                                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> فعال</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info mt-3">
                    <i class="bi bi-info-circle"></i>
                    هنوز قالب گزارشی تعریف نشده است. از
                    <a asp-controller="ReportTemplate" asp-action="Index">صفحه قالب‌های گزارش</a>
                    قالب جدید اضافه کنید.
                </div>
            }
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success px-4">
            <i class="bi bi-check-lg"></i> ذخیره تنظیمات
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-counterclockwise"></i> بازنشانی
        </a>
    </div>
</form>
