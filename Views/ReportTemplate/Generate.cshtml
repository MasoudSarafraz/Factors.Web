@model Factors.Web.Models.ViewModels.GenerateReportViewModel
@{
    ViewData["Title"] = $"تولید گزارش - {Model.TemplateName}";
    var factors = ViewBag.Factors as dynamic;
}

<div class="page-header">
    <h4><i class="bi bi-printer"></i> تولید گزارش از قالب</h4>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-right"></i> بازگشت
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-success text-white">
                <h6 class="mb-0">
                    <i class="bi bi-file-earmark-word"></i>
                    تولید گزارش: @Model.TemplateName
                </h6>
            </div>
            <div class="card-body">
                <form asp-action="Generate" method="post">
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <input type="hidden" asp-for="TemplateId" />

                    <div class="mb-4">
                        <label asp-for="FactorId" class="form-label fw-bold"></label>
                        <select asp-for="FactorId" class="form-select" required>
                            <option value="">انتخاب فاکتور...</option>
                            @if (factors != null)
                            {
                                foreach (var f in factors)
                                {
                                    <option value="@f.Id">
                                        فاکتور #@f.Id - @f.PersonName - @f.PersianDate - @(((decimal)f.TotalAmount).ToString("N0")) ریال
                                    </option>
                                }
                            }
                        </select>
                        <span asp-validation-for="FactorId" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-success btn-lg px-5">
                        <i class="bi bi-file-earmark-arrow-down"></i> تولید گزارش Word
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="bi bi-info-circle"></i> توضیحات</h6>
            </div>
            <div class="card-body">
                <p class="small text-muted mb-2">
                    با انتخاب فاکتور و کلیک روی دکمه تولید، سیستم مارکرهای قالب Word را با اطلاعات فاکتور پر کرده و فایل خروجی را دانلود می‌کند.
                </p>
                <div class="alert alert-warning small mb-0">
                    <i class="bi bi-exclamation-triangle"></i>
                    <strong>توجه:</strong> فایل خروجی در فرمت Word (.docx) خواهد بود. می‌توانید آن را در Word باز کرده و به PDF تبدیل کنید.
                </div>
            </div>
        </div>
    </div>
</div>
