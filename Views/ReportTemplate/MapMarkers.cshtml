@model Factors.Web.Models.ViewModels.MarkerMappingViewModel
@{
    ViewData["Title"] = $"نقشه‌برداری مارکرها - {Model.TemplateName}";
    var dataSources = Html.GetEnumSelectList<Factors.Web.Models.Entities.MarkerDataSource>();
}

<div class="page-header">
    <h4><i class="bi bi-link-45deg"></i> نقشه‌برداری مارکرها</h4>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-right"></i> بازگشت
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-light">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-file-earmark-word text-primary"></i>
            <strong>@Model.TemplateName</strong>
            <span class="badge bg-info">@Model.Markers.Count مارکر</span>
        </div>
    </div>
</div>

<form asp-action="MapMarkers" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="TemplateId" value="@Model.TemplateId" />

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-primary text-white">
            <h6 class="mb-0"><i class="bi bi-diagram-3"></i> تنظیم اتصال مارکرها به پراپرتی‌ها</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:30px">#</th>
                            <th style="width:180px">نام مارکر</th>
                            <th style="width:100px">نوع</th>
                            <th style="width:150px">منبع داده</th>
                            <th>پراپرتی</th>
                            <th style="width:80px">وضعیت</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Markers.Count; i++)
                        {
                            var marker = Model.Markers[i];
                            <tr>
                                <td class="text-muted">@(i + 1)</td>
                                <td>
                                    <input type="hidden" name="Mappings[@i].MarkerId" value="@marker.MarkerId" />
                                    <code class="fs-6" dir="ltr">{@marker.MarkerName}</code>
                                </td>
                                <td>
                                    @if (marker.DataType == Factors.Web.Models.Entities.MarkerDataType.List)
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-list-ul"></i> لیستی
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">
                                            <i class="bi bi-dot"></i> تکی
                                        </span>
                                    }
                                </td>
                                <td>
                                    <select name="Mappings[@i].DataSource" class="form-select form-select-sm"
                                            onchange="updateProperties(this, @i)">
                                        @foreach (var ds in dataSources)
                                        {
                                            <option value="@ds.Value"
                                                    selected="@(marker.DataSource.ToString() == ds.Value)">
                                                @ds.Text
                                            </option>
                                        }
                                    </select>
                                </td>
                                <td>
                                    <select name="Mappings[@i].PropertyPath" class="form-select form-select-sm property-select"
                                            data-index="@i">
                                        <option value="">-- انتخاب پراپرتی --</option>
                                        @if (marker.AvailableProperties != null)
                                        {
                                            foreach (var prop in marker.AvailableProperties)
                                            {
                                                <option value="@prop.Value"
                                                        selected="@(marker.PropertyPath == prop.Value)">
                                                    @prop.Label
                                                </option>
                                            }
                                        }
                                    </select>
                                </td>
                                <td>
                                    @if (marker.IsMapped)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-lg"></i></span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning"><i class="bi bi-exclamation"></i></span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white">
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted small">
                    <i class="bi bi-info-circle"></i>
                    مارکرهای لیستی مربوط به سطرهای جدول هستند و پراپرتی‌های آیتم فاکتور را دریافت می‌کنند
                </span>
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-check-lg"></i> ذخیره نقشه‌برداری
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script>
    // پراپرتی‌های هر منبع داده
    const propertiesBySource = {
        @Html.Raw(Json.Serialize(
            Enum.GetValues(typeof(Factors.Web.Models.Entities.MarkerDataSource))
                .Cast<Factors.Web.Models.Entities.MarkerDataSource>()
                .ToDictionary(
                    ds => ((int)ds).ToString(),
                    ds => Factors.Web.Models.ViewModels.AvailableProperties.GetPropertiesForDataSource(ds)
                )
        ))
    };

    function updateProperties(dataSourceSelect, index) {
        var sourceValue = dataSourceSelect.value;
        var props = propertiesBySource[sourceValue] || [];
        var propertySelect = document.querySelector(`select.property-select[data-index="${index}"]`);

        if (!propertySelect) return;

        var currentValue = propertySelect.value;
        propertySelect.innerHTML = '<option value="">-- انتخاب پراپرتی --</option>';

        props.forEach(function(prop) {
            var option = document.createElement('option');
            option.value = prop.value;
            option.textContent = prop.label;
            if (prop.value === currentValue) {
                option.selected = true;
            }
            propertySelect.appendChild(option);
        });
    }
</script>
}
