@model Factors.Web.Models.ViewModels.MarkerMappingViewModel
@using Factors.Web.Models.Entities
@using Factors.Web.Models.ViewModels
@{
    ViewData["Title"] = $"نقشه‌برداری مارکرها - {Model.TemplateName}";
    var totalMappable = Model.Groups.SelectMany(g =>
        g.IsList ? g.ChildMarkers : (IEnumerable<MarkerMappingItem>)new[] { g.MainMarker }).Count();
    var totalMapped = Model.Groups.SelectMany(g =>
        g.IsList ? g.ChildMarkers : (IEnumerable<MarkerMappingItem>)new[] { g.MainMarker }).Count(m => m.IsMapped);

    var typeInfo = Model.TemplateType switch
    {
        ReportTemplateType.SingleFactor => ("فاکتور تکی", "bi-receipt-cutoff", "bg-info"),
        ReportTemplateType.FactorList => ("لیست فاکتور", "bi-list-ol", "bg-primary"),
        ReportTemplateType.ProductList => ("محصولات", "bi-box", "bg-success"),
        ReportTemplateType.PersonList => ("اشخاص", "bi-people", "bg-warning"),
        _ => ("سفارشی", "bi-gear", "bg-secondary")
    };
}

<div class="page-header">
    <h4><i class="bi bi-link-45deg"></i> نقشه‌برداری مارکرها</h4>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-right"></i> بازگشت
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-light">
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <i class="bi bi-file-earmark-word text-primary"></i>
            <strong>@Model.TemplateName</strong>
            <span class="badge @typeInfo.Item3"><i class="bi @typeInfo.Item2"></i> @typeInfo.Item1</span>
            <span class="badge bg-info">@totalMappable مارکر قابل اتصال</span>
            <span class="badge bg-success">@totalMapped نقشه‌برداری شده</span>
        </div>
    </div>
</div>

<form asp-action="MapMarkers" method="post" id="mappingForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="TemplateId" value="@Model.TemplateId" />

    @{
        int idx = 0;
    }

    @foreach (var group in Model.Groups)
    {
        if (group.IsList)
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header py-2 px-3" style="background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-list-ul text-success"></i>
                        <span class="badge bg-success">لیستی</span>
                        <code class="fs-6" dir="ltr">{@group.MainMarker.MarkerName}</code>
                        <span class="text-muted small">— جدول با @group.ChildMarkers.Count ستون مارکر</span>
                        <span class="badge bg-light text-dark me-auto">
                            <i class="bi bi-info-circle"></i> ساختاری — نیازی به اتصال ندارد
                        </span>
                    </div>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:30px" class="text-center">#</th>
                                <th style="width:200px">مارکر</th>
                                <th style="width:180px">منبع داده</th>
                                <th>پراپرتی</th>
                                <th style="width:50px" class="text-center">وضعیت</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var child in group.ChildMarkers)
                            {
                                <tr>
                                    <td class="text-center text-muted small">@(idx + 1)</td>
                                    <td>
                                        <input type="hidden" name="Mappings[@idx].MarkerId" value="@child.MarkerId" />
                                        <div class="d-flex align-items-center gap-1">
                                            <i class="bi bi-arrow-return-left text-muted" style="font-size:0.75rem"></i>
                                            <code dir="ltr">{@child.MarkerName}</code>
                                        </div>
                                    </td>
                                    <td>
                                        <select name="Mappings[@idx].DataSource" class="form-select form-select-sm"
                                                data-idx="@idx" onchange="onDataSourceChange(this)">
                                            <option value="0" selected="@(child.DataSource == MarkerDataSource.Factor)">فاکتور</option>
                                            <option value="1" selected="@(child.DataSource == MarkerDataSource.FactorItem)">آیتم فاکتور</option>
                                            <option value="2" selected="@(child.DataSource == MarkerDataSource.Person)">مشتری</option>
                                            <option value="3" selected="@(child.DataSource == MarkerDataSource.Product)">محصول</option>
                                            <option value="4" selected="@(child.DataSource == MarkerDataSource.ProductCategory)">دسته‌بندی</option>
                                            <option value="5" selected="@(child.DataSource == MarkerDataSource.ProductPack)">بسته</option>
                                        </select>
                                    </td>
                                    <td>
                                        <select name="Mappings[@idx].PropertyPath" class="form-select form-select-sm property-select"
                                                id="prop_@idx" data-current="@child.PropertyPath">
                                            <option value="">-- انتخاب پراپرتی --</option>
                                            @if (child.AvailableProperties != null)
                                            {
                                                var currentGroup = "";
                                                foreach (var prop in child.AvailableProperties)
                                                {
                                                    if (prop.Group != currentGroup)
                                                    {
                                                        if (currentGroup != "")
                                                        {
                                                            @:</optgroup>
                                                        }
                                                        currentGroup = prop.Group;
                                                        @:<optgroup label="@prop.Group">
                                                    }
                                                    <option value="@prop.Value" selected="@(child.PropertyPath == prop.Value)">
                                                        @prop.Label
                                                    </option>
                                                }
                                                if (currentGroup != "")
                                                {
                                                    @:</optgroup>
                                                }
                                            }
                                        </select>
                                    </td>
                                    <td class="text-center">
                                        @if (child.IsMapped)
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-lg"></i></span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning"><i class="bi bi-exclamation"></i></span>
                                        }
                                    </td>
                                </tr>
                                idx++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm mb-2">
                <div class="card-body py-2 px-3">
                    <div class="row align-items-center g-2">
                        <div class="col-md-3">
                            <input type="hidden" name="Mappings[@idx].MarkerId" value="@group.MainMarker.MarkerId" />
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-info"><i class="bi bi-dot"></i> تکی</span>
                                <code class="fs-6" dir="ltr">{@group.MainMarker.MarkerName}</code>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <select name="Mappings[@idx].DataSource" class="form-select form-select-sm"
                                    data-idx="@idx" onchange="onDataSourceChange(this)">
                                <option value="0" selected="@(group.MainMarker.DataSource == MarkerDataSource.Factor)">فاکتور</option>
                                <option value="1" selected="@(group.MainMarker.DataSource == MarkerDataSource.FactorItem)">آیتم فاکتور</option>
                                <option value="2" selected="@(group.MainMarker.DataSource == MarkerDataSource.Person)">مشتری</option>
                                <option value="3" selected="@(group.MainMarker.DataSource == MarkerDataSource.Product)">محصول</option>
                                <option value="4" selected="@(group.MainMarker.DataSource == MarkerDataSource.ProductCategory)">دسته‌بندی</option>
                                <option value="5" selected="@(group.MainMarker.DataSource == MarkerDataSource.ProductPack)">بسته</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <select name="Mappings[@idx].PropertyPath" class="form-select form-select-sm property-select"
                                    id="prop_@idx" data-current="@group.MainMarker.PropertyPath">
                                <option value="">-- انتخاب پراپرتی --</option>
                                @if (group.MainMarker.AvailableProperties != null)
                                {
                                    var currentGroup = "";
                                    foreach (var prop in group.MainMarker.AvailableProperties)
                                    {
                                        if (prop.Group != currentGroup)
                                        {
                                            if (currentGroup != "")
                                            {
                                                @:</optgroup>
                                            }
                                            currentGroup = prop.Group;
                                            @:<optgroup label="@prop.Group">
                                        }
                                        <option value="@prop.Value" selected="@(group.MainMarker.PropertyPath == prop.Value)">
                                            @prop.Label
                                        </option>
                                    }
                                    if (currentGroup != "")
                                    {
                                        @:</optgroup>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-1 text-center">
                            @if (group.MainMarker.IsMapped)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-lg"></i></span>
                            }
                            else
                            {
                                <span class="badge bg-warning"><i class="bi bi-exclamation"></i></span>
                            }
                        </div>
                    </div>
                </div>
            </div>
            idx++;
        }
    }

    <div class="mt-3 d-flex justify-content-between align-items-center">
        <span class="text-muted small">
            <i class="bi bi-info-circle"></i>
            مارکرهای <span class="badge bg-success">لیستی</span> فقط ساختاری هستند و سطرهای جدول زیرشان تکرار می‌شود.
            مارکرهای <span class="badge bg-info">تکی</span> و مارکرهای داخل جدول باید به پراپرتی‌ها متصل شوند.
        </span>
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-check-lg"></i> ذخیره نقشه‌برداری
        </button>
    </div>
</form>

@section Scripts {
<script>
    var propsData = {
        "0": [  // Factor
            { group: "شناسایی", items: [
                { v: "Id", l: "شماره فاکتور" },
                { v: "Invoicenumber", l: "شماره پیش‌فاکتور" }
            ]},
            { group: "تاریخ", items: [
                { v: "PersianCreateDate", l: "تاریخ شمسی (کامل)" },
                { v: "date", l: "تاریخ شمسی (کوتاه)" },
                { v: "CreateDate", l: "تاریخ میلادی" }
            ]},
            { group: "مشتری", items: [
                { v: "PersonName", l: "نام مشتری" },
                { v: "Buyerdetails", l: "مشخصات خریدار" },
                { v: "PersonType", l: "نوع مشتری (حقیقی/حقوقی)" },
                { v: "PersonId", l: "شناسه مشتری" }
            ]},
            { group: "مبالغ", items: [
                { v: "TotalAmount", l: "جمع کل (بدون مالیات)" },
                { v: "sum", l: "جمع کل" },
                { v: "Totalup", l: "جمع بالایی" },
                { v: "TaxAmount", l: "مبلغ مالیات" },
                { v: "tax", l: "مالیات" },
                { v: "TaxPercent", l: "درصد مالیات" },
                { v: "TotalWithTax", l: "جمع با مالیات" },
                { v: "Totalsum", l: "جمع نهایی" }
            ]},
            { group: "تعداد", items: [
                { v: "TotalItems", l: "تعداد آیتم‌ها (سطرها)" },
                { v: "TotalQuantity", l: "تعداد کل اقلام" }
            ]}
        ],
        "1": [  // FactorItem
            { group: "نام و شرح", items: [
                { v: "ProductName", l: "نام کالا/محصول" },
                { v: "Descriptionofthepiece", l: "شرح قلم (نام محصول)" },
                { v: "ProductCode", l: "کد محصول" },
                { v: "CategoryName", l: "دسته‌بندی محصول" }
            ]},
            { group: "تعداد", items: [
                { v: "Qty", l: "تعداد" },
                { v: "PartQty", l: "تعداد قلم" }
            ]},
            { group: "قیمت", items: [
                { v: "Price", l: "قیمت واحد" },
                { v: "price", l: "قیمت واحد (کوتاه)" },
                { v: "TotalPrice", l: "قیمت کل سطر" },
                { v: "total", l: "قیمت کل (کوتاه)" }
            ]},
            { group: "سطر", items: [
                { v: "RowNumber", l: "شماره سطر" }
            ]},
            { group: "بسته", items: [
                { v: "IsPack", l: "آیا بسته است؟" },
                { v: "PackName", l: "نام بسته" },
                { v: "PackId", l: "شناسه بسته" }
            ]},
            { group: "شناسه", items: [
                { v: "ItemId", l: "شناسه آیتم" },
                { v: "SalableId", l: "شناسه محصول" }
            ]}
        ],
        "2": [  // Person
            { group: "نام", items: [
                { v: "PersonName", l: "نام شخص/شرکت" },
                { v: "Buyerdetails", l: "مشخصات خریدار" }
            ]},
            { group: "نوع", items: [
                { v: "PersonType", l: "نوع (حقیقی/حقوقی)" },
                { v: "IsIndividual", l: "آیا حقیقی است؟" }
            ]},
            { group: "شناسه", items: [
                { v: "Id", l: "شناسه مشتری" }
            ]},
            { group: "تاریخ", items: [
                { v: "PersianCreateDate", l: "تاریخ شمسی ثبت" }
            ]},
            { group: "آمار فاکتور", items: [
                { v: "TotalFactors", l: "تعداد فاکتورها" },
                { v: "TotalPurchaseAmount", l: "مجموع خرید" }
            ]}
        ],
        "3": [  // Product
            { group: "نام و کد", items: [
                { v: "ProductName", l: "نام محصول" },
                { v: "ProductCode", l: "کد محصول" }
            ]},
            { group: "دسته‌بندی", items: [
                { v: "CategoryName", l: "نام دسته‌بندی" }
            ]},
            { group: "قیمت", items: [
                { v: "CurrentPrice", l: "قیمت فعلی" }
            ]},
            { group: "شناسه", items: [
                { v: "Id", l: "شناسه محصول" }
            ]},
            { group: "تاریخ", items: [
                { v: "PersianCreateDate", l: "تاریخ شمسی ثبت" }
            ]},
            { group: "آمار فروش", items: [
                { v: "TotalSoldQty", l: "تعداد فروش رفته" },
                { v: "TotalSoldAmount", l: "مجموع فروش" }
            ]}
        ],
        "4": [  // ProductCategory
            { group: "نام", items: [
                { v: "CategoryName", l: "نام دسته‌بندی" }
            ]},
            { group: "شناسه", items: [
                { v: "Id", l: "شناسه دسته‌بندی" }
            ]},
            { group: "آمار", items: [
                { v: "ProductCount", l: "تعداد محصولات" }
            ]}
        ],
        "5": [  // ProductPack
            { group: "نام", items: [
                { v: "PackName", l: "نام بسته" },
                { v: "PackCode", l: "کد بسته" }
            ]},
            { group: "شناسه", items: [
                { v: "Id", l: "شناسه بسته" }
            ]},
            { group: "قیمت", items: [
                { v: "TotalPackPrice", l: "مجموع قیمت بسته" }
            ]},
            { group: "آمار", items: [
                { v: "ItemCount", l: "تعداد اقلام بسته" }
            ]}
        ]
    };

    function onDataSourceChange(dsSelect) {
        var idx = dsSelect.getAttribute('data-idx');
        var propSelect = document.getElementById('prop_' + idx);
        if (!propSelect) return;

        var sourceValue = dsSelect.value;
        var currentVal = propSelect.getAttribute('data-current');
        var groups = propsData[sourceValue] || [];

        var html = '<option value="">-- انتخاب پراپرتی --</option>';
        groups.forEach(function(g) {
            html += '<optgroup label="' + g.group + '">';
            g.items.forEach(function(p) {
                var sel = (p.v === currentVal) ? ' selected' : '';
                html += '<option value="' + p.v + '"' + sel + '>' + p.l + '</option>';
            });
            html += '</optgroup>';
        });

        propSelect.innerHTML = html;
    }
</script>
}
