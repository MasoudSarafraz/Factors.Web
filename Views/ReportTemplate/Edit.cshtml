@model Factors.Web.Models.ViewModels.ReportTemplateEditViewModel
@using Factors.Web.Models.Entities
@{
    ViewData["Title"] = $"ویرایش قالب: {Model.Name}";
}

<div class="page-header">
    <h4><i class="bi bi-pencil-square"></i> ویرایش قالب گزارش</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-right"></i> بازگشت
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex align-items-center gap-2 py-2 px-3">
                <span class="d-inline-flex align-items-center justify-content-center" style="width:28px;height:28px;border-radius:7px;background:linear-gradient(135deg,#4361ee,#3a86ff);color:#fff;font-size:0.85rem;">
                    <i class="bi bi-pencil-square"></i>
                </span>
                <span class="fw-bold" style="font-size:0.9rem;">ویرایش اطلاعات قالب</span>
            </div>
            <div class="card-body p-3">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label mb-1" style="font-size:0.8rem;font-weight:600;">نام قالب</label>
                        <input asp-for="Name" class="form-control form-control-sm" placeholder="مثلاً: فاکتور رسمی، رسید، پیش‌فاکتور..." />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label mb-1" style="font-size:0.8rem;">توضیحات</label>
                        <textarea asp-for="Description" class="form-control form-control-sm" rows="2" placeholder="توضیح مختصر درباره این قالب..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label mb-1" style="font-size:0.8rem;font-weight:600;">نوع گزارش</label>
                        <div class="row g-2">
                            <div class="col-md-4">
                                <label class="card border h-100 p-2 template-type-card @(Model.TemplateType == ReportTemplateType.SingleFactor ? "border-primary" : "")" style="cursor:pointer">
                                    <div class="d-flex align-items-center gap-2">
                                        <input type="radio" name="TemplateType" value="0" class="form-check-input"
                                               checked="@(Model.TemplateType == ReportTemplateType.SingleFactor)" onchange="updateTypeCard(this)" />
                                        <div>
                                            <strong class="small"><i class="bi bi-receipt-cutoff"></i> فاکتور تکی</strong>
                                            <div class="text-muted" style="font-size:0.7rem">فاکتور، رسید، پیش‌فاکتور</div>
                                        </div>
                                    </div>
                                </label>
                            </div>
                            <div class="col-md-4">
                                <label class="card border h-100 p-2 template-type-card @(Model.TemplateType == ReportTemplateType.FactorList ? "border-primary" : "")" style="cursor:pointer">
                                    <div class="d-flex align-items-center gap-2">
                                        <input type="radio" name="TemplateType" value="1" class="form-check-input"
                                               checked="@(Model.TemplateType == ReportTemplateType.FactorList)" onchange="updateTypeCard(this)" />
                                        <div>
                                            <strong class="small"><i class="bi bi-list-ol"></i> لیست فاکتورها</strong>
                                            <div class="text-muted" style="font-size:0.7rem">گزارش فروش، گزارش دوره‌ای</div>
                                        </div>
                                    </div>
                                </label>
                            </div>
                            <div class="col-md-4">
                                <label class="card border h-100 p-2 template-type-card @(Model.TemplateType == ReportTemplateType.ProductList ? "border-primary" : "")" style="cursor:pointer">
                                    <div class="d-flex align-items-center gap-2">
                                        <input type="radio" name="TemplateType" value="2" class="form-check-input"
                                               checked="@(Model.TemplateType == ReportTemplateType.ProductList)" onchange="updateTypeCard(this)" />
                                        <div>
                                            <strong class="small"><i class="bi bi-box"></i> لیست محصولات</strong>
                                            <div class="text-muted" style="font-size:0.7rem">لیست قیمت، کاتالوگ</div>
                                        </div>
                                    </div>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label mb-1" style="font-size:0.8rem;font-weight:600;">جایگزینی فایل قالب</label>
                        <div class="d-flex align-items-center gap-2 mb-2 p-2 rounded-2" style="background:#f8fafc;">
                            <i class="bi bi-file-earmark-word text-primary"></i>
                            <span class="small text-muted">فایل فعلی:</span>
                            <span class="small fw-bold">@Model.OriginalFileName</span>
                        </div>
                        <input asp-for="TemplateFile" class="form-control form-control-sm" accept=".docx" />
                        <span asp-validation-for="TemplateFile" class="text-danger small"></span>
                        <div class="form-text" style="font-size:0.75rem;">
                            <i class="bi bi-info-circle"></i>
                            اگر فایل جدید انتخاب کنید، فایل قبلی جایگزین و مارکرها مجدداً استخراج می‌شوند. اگر خالی بگذارید، فایل قبلی حفظ می‌شود.
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-sm px-4">
                            <i class="bi bi-check-lg"></i> ذخیره تغییرات
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-x-lg"></i> انصراف
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header-compact">
                <span class="icon-badge icon-badge-orange"><i class="bi bi-exclamation-triangle"></i></span>
                <span class="header-title">نکات مهم</span>
            </div>
            <div class="card-body">
                <div class="alert alert-warning small mb-2">
                    <i class="bi bi-exclamation-triangle"></i>
                    <strong>تغییر نوع قالب:</strong> اگر نوع قالب را تغییر دهید، نقشه‌برداری مارکرها ممکن است نیاز به تنظیم مجدد داشته باشد.
                </div>
                <div class="alert alert-info small mb-0">
                    <i class="bi bi-info-circle"></i>
                    <strong>جایگزینی فایل:</strong> با آپلود فایل جدید، مارکرهای قبلی حذف و مارکرهای جدید استخراج می‌شوند. حتماً پس از جایگزینی، نقشه‌برداری مارکرها را بررسی کنید.
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .template-type-card {
        transition: all 0.15s ease;
    }
    .template-type-card:has(input:checked) {
        border-color: #4361ee !important;
        background: #f0efff;
    }
    .template-type-card:hover {
        border-color: #999 !important;
    }
</style>

@section Scripts {
<script>
    function updateTypeCard(radio) {
        document.querySelectorAll('.template-type-card').forEach(function(c) {
            c.classList.remove('border-primary');
        });
        radio.closest('.template-type-card').classList.add('border-primary');
    }
</script>
}
