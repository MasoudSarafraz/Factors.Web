@using System.Security.Claims
@inject IPermissionService PermissionService
@{
    var userId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    int uid = 0;
    if (!string.IsNullOrEmpty(userId)) int.TryParse(userId, out uid);
    var isAdmin = User.IsInRole("Admin");
    
    // Cache permissions for this request
    var userPerms = isAdmin ? null : (uid > 0 ? await PermissionService.GetUserPermissionNamesAsync(uid) : new HashSet<string>());
    bool HasPerm(string perm) => isAdmin || (userPerms != null && userPerms.Contains(perm));
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - سیستم مدیریت فاکتور</title>
    <!-- IRANSans Font -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css" />
    <!-- Bootstrap 5 RTL -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- Select2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <!-- Persian DatePicker -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/persian-datepicker@1.2.0/dist/css/persian-datepicker.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <!-- Top Navbar -->
    <nav class="navbar navbar-dark bg-dark fixed-top px-3 shadow-sm" style="z-index:1040">
        <div class="d-flex align-items-center">
            <button class="btn btn-dark me-2 p-1" id="sidebarToggle" title="منوی کناری">
                <i class="bi bi-list fs-5"></i>
            </button>
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-receipt"></i> سیستم فاکتور
            </a>
        </div>
        <div class="d-flex align-items-center">
            <span class="text-light small me-3 d-none d-md-inline">
                <i class="bi bi-calendar3"></i> @Factors.Web.Models.Entities.PersianDateService.Now
            </span>
            <div class="dropdown">
                <a class="btn btn-outline-light btn-sm dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                    <i class="bi bi-person-circle"></i> @User.Identity?.Name
                </a>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="dropdown-item">
                                <i class="bi bi-box-arrow-left"></i> خروج
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Sidebar -->
    <div class="sidebar bg-white shadow-sm" id="sidebar">
        <div class="sidebar-content">
            <!-- Dashboard -->
            @if (HasPerm("Dashboard.View"))
            {
                <div class="sidebar-section">
                    <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> داشبورد
                    </a>
                </div>
            }

            <!-- تعریف اطلاعات -->
            @{
                var showCategory = HasPerm("Category.View");
                var showProduct = HasPerm("Product.View");
                var showPerson = HasPerm("Person.View");
                var showPack = HasPerm("Pack.View");
            }
            @if (showCategory || showProduct || showPerson || showPack)
            {
                <div class="sidebar-section">
                    <div class="sidebar-heading">تعریف اطلاعات</div>
                    @if (showCategory)
                    {
                        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Category" ? "active" : "")" asp-controller="Category" asp-action="Index">
                            <i class="bi bi-folder"></i> دسته‌بندی‌ها
                        </a>
                    }
                    @if (showProduct)
                    {
                        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Product" ? "active" : "")" asp-controller="Product" asp-action="Index">
                            <i class="bi bi-box"></i> محصولات
                        </a>
                    }
                    @if (showPerson)
                    {
                        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Person" ? "active" : "")" asp-controller="Person" asp-action="Index">
                            <i class="bi bi-people"></i> اشخاص
                        </a>
                    }
                    @if (showPack)
                    {
                        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Pack" ? "active" : "")" asp-controller="Pack" asp-action="Index">
                            <i class="bi bi-box-seam"></i> بسته‌ها
                        </a>
                    }
                </div>
            }

            <!-- عملیات -->
            @if (HasPerm("Factor.View"))
            {
                <div class="sidebar-section">
                    <div class="sidebar-heading">عملیات</div>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Factor" ? "active" : "")" asp-controller="Factor" asp-action="Index">
                        <i class="bi bi-receipt-cutoff"></i> فاکتورها
                    </a>
                </div>
            }

            <!-- گزارش‌سازی -->
            @{
                var showReportBuilder = HasPerm("ReportBuilder.View");
                var showReport = HasPerm("Report.View");
                var showTemplate = HasPerm("ReportTemplate.View");
            }
            @if (showReportBuilder || showReport || showTemplate)
            {
                <div class="sidebar-section">
                    <div class="sidebar-heading">گزارش‌سازی</div>
                    @if (showReportBuilder)
                    {
                        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "ReportBuilder" ? "active" : "")" asp-controller="ReportBuilder" asp-action="Index">
                            <i class="bi bi-magic"></i> مرکز گزارش‌سازی
                        </a>
                    }
                    @if (showReport)
                    {
                        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Report" ? "active" : "")" asp-controller="Report" asp-action="Index">
                            <i class="bi bi-file-earmark-bar-graph"></i> گزارشات PDF
                        </a>
                    }
                    @if (showTemplate)
                    {
                        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "ReportTemplate" ? "active" : "")" asp-controller="ReportTemplate" asp-action="Index">
                            <i class="bi bi-file-earmark-word"></i> قالب‌های گزارش
                        </a>
                    }
                </div>
            }

            <!-- تنظیمات -->
            @{
                var showSettings = HasPerm("Settings.View");
                var showUsers = HasPerm("User.View");
            }
            @if (showSettings || showUsers)
            {
                <div class="sidebar-section">
                    <div class="sidebar-heading">تنظیمات</div>
                    @if (showSettings)
                    {
                        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Settings" ? "active" : "")" asp-controller="Settings" asp-action="Index">
                            <i class="bi bi-gear"></i> تنظیمات سیستم
                        </a>
                    }
                    @if (showUsers)
                    {
                        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "User" ? "active" : "")" asp-controller="User" asp-action="Index">
                            <i class="bi bi-person-gear"></i> مدیریت کاربران
                        </a>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Sidebar Overlay (mobile) -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Main Content -->
    <div class="main-content" id="mainContent">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()

        <footer class="border-top text-muted mt-4 py-3 text-center">
            <small>&copy; @Factors.Web.Models.Entities.PersianDateService.CurrentPersianYear - سیستم مدیریت فاکتور</small>
        </footer>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/persian-date@1.1.0/dist/persian-date.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/persian-datepicker@1.2.0/dist/js/persian-datepicker.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
