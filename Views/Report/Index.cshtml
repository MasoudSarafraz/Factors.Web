@model Factors.Web.Models.ViewModels.ReportFilterViewModel
@{
    ViewData["Title"] = "گزارشات";
    var persons = ViewBag.Persons as IEnumerable<Factors.Web.Models.Entities.Person>;
    var categories = ViewBag.Categories as IEnumerable<Factors.Web.Models.Entities.ProductCategory>;
    var products = ViewBag.Products as IEnumerable<Factors.Web.Models.Entities.Product>;
}

<div class="page-header">
    <h4><i class="bi bi-file-earmark-bar-graph"></i> گزارشات</h4>
</div>

<div class="row">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header-compact">
                <span class="icon-badge icon-badge-blue"><i class="bi bi-funnel"></i></span>
                <span class="header-title">فیلتر گزارش</span>
            </div>
            <div class="card-body">
                <form asp-action="Generate" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label-compact">نوع گزارش</label>
                        <select name="ReportType" class="form-select form-select-sm" id="reportType">
                            <option value="factors">گزارش فاکتورها</option>
                            <option value="sales">گزارش فروش</option>
                            <option value="products">گزارش محصولات</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label-compact">از تاریخ (شمسی)</label>
                        <input type="text" name="FromDateJalali" class="form-control form-control-sm persian-datepicker" placeholder="مثال: 1403/01/01" autocomplete="off" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label-compact">تا تاریخ (شمسی)</label>
                        <input type="text" name="ToDateJalali" class="form-control form-control-sm persian-datepicker" placeholder="مثال: 1403/12/29" autocomplete="off" />
                    </div>

                    <div class="mb-3" id="personFilter">
                        <label class="form-label-compact">مشتری</label>
                        <select name="PersonId" class="form-select form-select-sm">
                            <option value="">همه مشتریان</option>
                            @if (persons != null)
                            {
                                foreach (var p in persons)
                                {
                                    <option value="@p.Id">@p.PersonName</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3" id="categoryFilter" style="display:none;">
                        <label class="form-label-compact">دسته‌بندی</label>
                        <select name="CategoryId" class="form-select form-select-sm">
                            <option value="">همه دسته‌بندی‌ها</option>
                            @if (categories != null)
                            {
                                foreach (var c in categories)
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3" id="productFilter" style="display:none;">
                        <label class="form-label-compact">محصول</label>
                        <select name="ProductId" class="form-select form-select-sm">
                            <option value="">همه محصولات</option>
                            @if (products != null)
                            {
                                foreach (var p in products)
                                {
                                    <option value="@p.Id">@p.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary btn-sm w-100 fw-bold">
                        <i class="bi bi-file-earmark-pdf"></i> تولید گزارش PDF
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header-compact">
                <span class="icon-badge icon-badge-teal"><i class="bi bi-info-circle"></i></span>
                <span class="header-title">راهنمای گزارشات</span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="card bg-white border h-100">
                            <div class="card-body text-center p-3">
                                <div class="stat-icon mx-auto mb-2" style="background:#eef0ff;color:var(--primary-color);width:40px;height:40px;">
                                    <i class="bi bi-receipt-cutoff"></i>
                                </div>
                                <h6 class="fw-bold mb-1">گزارش فاکتورها</h6>
                                <p class="text-muted small mb-0">لیست فاکتورها با فیلتر تاریخ و مشتری. شامل جزئیات و مبالغ</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card bg-white border h-100">
                            <div class="card-body text-center p-3">
                                <div class="stat-icon mx-auto mb-2" style="background:#e6faf7;color:var(--success-color);width:40px;height:40px;">
                                    <i class="bi bi-graph-up"></i>
                                </div>
                                <h6 class="fw-bold mb-1">گزارش فروش</h6>
                                <p class="text-muted small mb-0">خلاصه فروش بازه زمانی. تعداد فاکتور، مبلغ کل و آمار</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card bg-white border h-100">
                            <div class="card-body text-center p-3">
                                <div class="stat-icon mx-auto mb-2" style="background:#fff7e6;color:var(--warning-color);width:40px;height:40px;">
                                    <i class="bi bi-box"></i>
                                </div>
                                <h6 class="fw-bold mb-1">گزارش محصولات</h6>
                                <p class="text-muted small mb-0">لیست محصولات با فیلتر دسته‌بندی. شامل قیمت‌های فعال</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $('#reportType').change(function() {
        var type = $(this).val();
        $('#personFilter').hide();
        $('#categoryFilter').hide();
        $('#productFilter').hide();

        if (type === 'factors' || type === 'sales') {
            $('#personFilter').show();
        } else if (type === 'products') {
            $('#categoryFilter').show();
            $('#productFilter').show();
        }
    });

    // Re-init datepickers after partial load
    setTimeout(function() { initPersianDatepickers(); }, 200);
</script>
}
