@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ورود به سیستم - سیستم مدیریت فاکتور</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="bg-light">
    <div class="container">
        <div class="row justify-content-center mt-5">
            <div class="col-md-5">
                <div class="card shadow-lg border-0 rounded-4">
                    <div class="card-header bg-primary text-white text-center py-3 rounded-top-4">
                        <h4 class="mb-0"><i class="bi bi-receipt"></i> سیستم مدیریت فاکتور</h4>
                    </div>
                    <div class="card-body p-4">
                        <form asp-controller="Account" asp-action="Login" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                            
                            <div class="mb-3">
                                <label class="form-label fw-bold">نام کاربری</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                                    <input type="text" name="Username" class="form-control" placeholder="نام کاربری خود را وارد کنید" required autofocus />
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label fw-bold">رمز عبور</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                    <input type="password" name="Password" class="form-control" placeholder="رمز عبور خود را وارد کنید" required />
                                </div>
                            </div>
                            
                            <div class="mb-3 form-check">
                                <input type="checkbox" name="RememberMe" class="form-check-input" />
                                <label class="form-check-label">مرا به خاطر بسپار</label>
                            </div>
                            
                            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">
                                <i class="bi bi-box-arrow-in-left"></i> ورود
                            </button>
                        </form>
                    </div>
                    <div class="card-footer text-center text-muted bg-light">
                        <small>حساب پیش‌فرض: admin / Admin@123</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
