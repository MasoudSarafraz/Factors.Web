@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ورود به سیستم - سیستم مدیریت فاکتور</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .login-card {
            border-radius: 1rem;
            overflow: hidden;
        }
        .login-card .card-header {
            padding: 1.5rem;
        }
        .login-card .card-body {
            padding: 2rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-sm-8">
                <div class="card login-card shadow-lg border-0">
                    <div class="card-header bg-white text-center border-0">
                        <div class="mb-2">
                            <i class="bi bi-receipt text-primary" style="font-size:2.5rem;"></i>
                        </div>
                        <h4 class="fw-bold text-dark mb-0">سیستم مدیریت فاکتور</h4>
                        <small class="text-muted">برای ادامه وارد حساب کاربری شوید</small>
                    </div>
                    <div class="card-body">
                        <form asp-controller="Account" asp-action="Login" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                            <div class="mb-3">
                                <label class="form-label fw-bold">نام کاربری</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-person"></i></span>
                                    <input type="text" name="Username" class="form-control" placeholder="نام کاربری خود را وارد کنید" required autofocus />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">رمز عبور</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-lock"></i></span>
                                    <input type="password" name="Password" class="form-control" placeholder="رمز عبور خود را وارد کنید" required />
                                </div>
                            </div>

                            <div class="mb-4 form-check">
                                <input type="checkbox" name="RememberMe" class="form-check-input" />
                                <label class="form-check-label small">مرا به خاطر بسپار</label>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" style="border-radius:0.5rem;">
                                <i class="bi bi-box-arrow-in-left"></i> ورود
                            </button>
                        </form>
                    </div>
                    <div class="card-footer text-center text-muted bg-light border-0">
                        <small>حساب پیش‌فرض: admin / Admin@123</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
