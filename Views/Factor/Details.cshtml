@model Factors.Web.Models.ViewModels.FactorViewModel
@{
    ViewData["Title"] = $"فاکتور شماره {Model.Id}";
}

<div class="page-header">
    <h4><i class="bi bi-receipt-cutoff"></i> فاکتور شماره @Model.Id</h4>
    <div class="d-flex gap-2">
        <a asp-action="Print" asp-route-id="@Model.Id" class="btn btn-success" target="_blank">
            <i class="bi bi-printer"></i> چاپ PDF
        </a>
        <a asp-controller="ReportBuilder" asp-action="Index" class="btn btn-info" target="_blank">
            <i class="bi bi-magic"></i> گزارش Word
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-right"></i> بازگشت
        </a>
    </div>
</div>

<!-- Factor Header -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
    <div class="row g-3">
            <div class="col-sm-4">
                <div class="d-flex align-items-center p-2 rounded-2" style="background:#f8fafc;">
                    <div class="stat-icon me-3" style="background:#eef0ff;color:#4361ee;">
                        <i class="bi bi-hash"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block">شماره فاکتور</small>
                        <strong class="fs-5">@Model.Id</strong>
                    </div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="d-flex align-items-center p-2 rounded-2" style="background:#f8fafc;">
                    <div class="stat-icon me-3" style="background:#e6faf7;color:#2ec4b6;">
                        <i class="bi bi-person"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block">مشتری</small>
                        <strong>@Model.PersonName</strong>
                    </div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="d-flex align-items-center p-2 rounded-2" style="background:#f8fafc;">
                    <div class="stat-icon me-3" style="background:#fff7e6;color:#ff9f1c;">
                        <i class="bi bi-calendar"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block">تاریخ</small>
                        <strong>@Model.PersianCreateDate</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Factor Items (Parent/Child with Collapse) -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-bold"><i class="bi bi-list-ul text-primary"></i> آیتم‌های فاکتور</h6>
        <span class="badge bg-light text-dark">@Model.TotalItems آیتم</span>
    </div>
    <div class="card-body" id="factorItemsContainer">
        @{
            int rowNum = 1;
            var packGroups = Model.Items
                .Where(i => i.PackId.HasValue && !i.ParentId.HasValue)
                .ToList();

            var childItems = Model.Items
                .Where(i => i.ParentId.HasValue)
                .ToList();

            var standaloneItems = Model.Items
                .Where(i => !i.PackId.HasValue && !i.ParentId.HasValue)
                .ToList();
        }

        @if (!Model.Items.Any())
        {
            <div class="text-center text-muted py-4">
                <i class="bi bi-inbox" style="font-size:2rem;"></i>
                <p class="mt-2 mb-0">آیتمی وجود ندارد</p>
            </div>
        }

        @foreach (var pack in packGroups)
        {
            var packChildren = Model.Items.Where(i => i.ParentId == pack.PackId).ToList();
            var packTotal = packChildren.Sum(c => c.Price * c.Qty);
            var collapseId = $"pack-collapse-{pack.PackId}";

            <div class="pack-item mb-2">
                <div class="d-flex align-items-center justify-content-between pack-header px-3 py-2 rounded-2" style="background:#eef0ff;cursor:pointer;" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                    <div class="d-flex align-items-center">
                        <span class="badge bg-primary me-2" style="min-width:28px">@rowNum</span>
                        <i class="bi bi-box-seam text-primary me-2"></i>
                        <strong>@pack.ProductName</strong>
                        <span class="text-muted small ms-3">× @pack.Qty.ToString("N0")</span>
                        <span class="badge bg-light text-dark ms-2">@packChildren.Count زیرآیتم</span>
                        <i class="bi bi-chevron-left small text-muted ms-1"></i>
                    </div>
                    <div class="d-flex align-items-center">
                        <span class="text-success fw-bold">@packTotal.ToString("N0") ریال</span>
                    </div>
                </div>
                <div class="collapse" id="@collapseId">
                    <div class="ps-4 pe-3 py-1">
                        @foreach (var child in packChildren)
                        {
                            var childTotal = child.Price * child.Qty;
                            <div class="d-flex align-items-center justify-content-between py-2 border-bottom" style="border-color:#edf2f7 !important;">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-arrow-return-left text-muted me-2"></i>
                                    <i class="bi bi-box text-secondary me-2" style="font-size:0.85rem;"></i>
                                    <span class="text-muted">@child.ProductName</span>
                                </div>
                                <div class="d-flex align-items-center gap-3 small text-muted">
                                    <span>@child.Qty.ToString("N0") عدد</span>
                                    <span>@child.Price.ToString("N0") ریال</span>
                                    <span class="text-dark fw-bold">@childTotal.ToString("N0") ریال</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            rowNum++;
        }

        @foreach (var item in standaloneItems)
        {
            var itemTotal = item.Price * item.Qty;
            <div class="d-flex align-items-center justify-content-between px-3 py-2 rounded-2 mb-1" style="background:#f8fafc;">
                <div class="d-flex align-items-center">
                    <span class="badge bg-light text-dark me-2" style="min-width:28px">@rowNum</span>
                    <i class="bi bi-box text-secondary me-2"></i>
                    <span>@item.ProductName</span>
                    <span class="text-muted small ms-3">× @item.Qty.ToString("N0")</span>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <span class="text-muted small">@item.Price.ToString("N0") ریال/واحد</span>
                    <span class="fw-bold">@itemTotal.ToString("N0") ریال</span>
                </div>
            </div>
            rowNum++;
        }
    </div>
    <div class="card-footer bg-white border-top">
        <div class="d-flex justify-content-between align-items-center">
            <span class="fw-bold fs-5">جمع کل:</span>
            <span class="fw-bold text-success fs-4">@Model.TotalAmount.ToString("N0") ریال</span>
        </div>
    </div>
</div>

<!-- Actions -->
<div class="d-flex gap-2">
    <a asp-action="Print" asp-route-id="@Model.Id" class="btn btn-success" target="_blank">
        <i class="bi bi-printer"></i> چاپ PDF
    </a>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('آیا از حذف این فاکتور مطمئن هستید؟')">
            <button type="submit" class="btn btn-outline-danger">
                <i class="bi bi-trash"></i> حذف فاکتور
            </button>
        </form>
    }
</div>


