@{
    ViewData["Title"] = "صدور فاکتور";
    var persons = ViewBag.Persons as dynamic;
    var products = ViewBag.Products as dynamic;
    var packs = ViewBag.Packs as dynamic;
}
@Html.AntiForgeryToken()

<div class="page-header">
    <h4><i class="bi bi-receipt-cutoff"></i> صدور فاکتور جدید</h4>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-right"></i> بازگشت
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <!-- Factor Info -->
        <div class="card border-0 shadow-sm rounded-3 mb-3">
            <div class="card-header bg-primary text-white">
                <h6 class="mb-0"><i class="bi bi-info-circle"></i> اطلاعات فاکتور</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">مشتری</label>
                        <select id="personSelect" class="form-select" required>
                            <option value="">انتخاب مشتری...</option>
                            @foreach (var p in persons)
                            {
                                <option value="@p.Id">@p.PersonName (@(p.IsIndividual ? "حقیقی" : "حقوقی"))</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">تاریخ</label>
                        <input type="text" class="form-control" value="@Factors.Web.Models.Entities.PersianDateService.Now" readonly />
                    </div>
                </div>
            </div>
        </div>

        <!-- Add Product/Pack to Factor -->
        <div class="card border-0 shadow-sm rounded-3 mb-3">
            <div class="card-header bg-info text-white">
                <h6 class="mb-0"><i class="bi bi-plus-circle"></i> افزودن آیتم</h6>
            </div>
            <div class="card-body">
                <ul class="nav nav-tabs mb-3" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#productTab" type="button">محصول</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#packTab" type="button">بسته</button>
                    </li>
                </ul>
                <div class="tab-content">
                    <!-- Product Tab -->
                    <div class="tab-pane fade show active" id="productTab">
                        <div class="row g-2">
                            <div class="col-md-5">
                                <select id="productSelect" class="form-select">
                                    <option value="">انتخاب محصول...</option>
                                    @foreach (var p in products)
                                    {
                                        <option value="@p.Id" data-code="@p.Code">@p.Name (@p.Code)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <input type="number" id="productQty" class="form-control" placeholder="تعداد" min="1" value="1" />
                            </div>
                            <div class="col-md-3">
                                <input type="number" id="productPrice" class="form-control" placeholder="قیمت واحد" min="0" />
                            </div>
                            <div class="col-md-2">
                                <button type="button" class="btn btn-success w-100" onclick="addProductItem()">
                                    <i class="bi bi-plus"></i> افزودن
                                </button>
                            </div>
                        </div>
                    </div>
                    <!-- Pack Tab -->
                    <div class="tab-pane fade" id="packTab">
                        <div class="row g-2">
                            <div class="col-md-5">
                                <select id="packSelect" class="form-select">
                                    <option value="">انتخاب بسته...</option>
                                    @foreach (var p in packs)
                                    {
                                        <option value="@p.Id" data-code="@p.PackCode">@p.PackName (@p.PackCode)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <input type="number" id="packQty" class="form-control" placeholder="تعداد" min="1" value="1" />
                            </div>
                            <div class="col-md-2">
                                <button type="button" class="btn btn-success w-100" onclick="addPackItem()">
                                    <i class="bi bi-plus"></i> افزودن
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Factor Items Table -->
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold"><i class="bi bi-list-ul"></i> آیتم‌های فاکتور</h6>
                <span id="itemCount" class="badge bg-primary">0 آیتم</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0" id="factorItemsTable">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>نام کالا/بسته</th>
                                <th>تعداد</th>
                                <th>قیمت واحد</th>
                                <th>جمع</th>
                                <th style="width:60px">حذف</th>
                            </tr>
                        </thead>
                        <tbody id="factorItemsBody">
                            <tr id="emptyRow">
                                <td colspan="6" class="text-center text-muted py-3">هنوز آیتمی اضافه نشده است</td>
                            </tr>
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="4" class="text-start fw-bold">جمع کل:</td>
                                <td class="fw-bold text-success" id="totalAmount">0 ریال</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <!-- Quick Actions -->
        <div class="card border-0 shadow-sm rounded-3 mb-3">
            <div class="card-header bg-success text-white">
                <h6 class="mb-0"><i class="bi bi-lightning"></i> عملیات سریع</h6>
            </div>
            <div class="card-body">
                <button type="button" class="btn btn-success w-100 mb-2 py-2 fw-bold" onclick="saveFactor()">
                    <i class="bi bi-check-circle"></i> ثبت فاکتور
                </button>
                <button type="button" class="btn btn-outline-secondary w-100 mb-2" onclick="clearAll()">
                    <i class="bi bi-arrow-counterclockwise"></i> پاک کردن همه
                </button>
                <a asp-action="Index" class="btn btn-outline-danger w-100">
                    <i class="bi bi-x-circle"></i> انصراف
                </a>
            </div>
        </div>

        <!-- Factor Summary -->
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-header bg-warning text-dark">
                <h6 class="mb-0"><i class="bi bi-calculator"></i> خلاصه فاکتور</h6>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span>تعداد آیتم‌ها:</span>
                    <strong id="summaryItems">0</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>جمع کل:</span>
                    <strong id="summaryTotal" class="text-success">0 ریال</strong>
                </div>
                <hr />
                <div class="d-flex justify-content-between">
                    <span class="fw-bold">مبلغ نهایی:</span>
                    <strong id="summaryFinal" class="text-success fs-5">0 ریال</strong>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Factor items stored in memory
    let factorItems = [];
    let packData = @Html.Raw(Json.Serialize(packs));

    // Auto-fill price when product selected
    $('#productSelect').change(function() {
        var productId = $(this).val();
        if (productId) {
            $.get('/Factor/GetProductCurrentPrice?productId=' + productId, function(data) {
                if (data.price > 0) {
                    $('#productPrice').val(data.price);
                }
            });
        }
    });

    function addProductItem() {
        var productId = $('#productSelect').val();
        var productName = $('#productSelect option:selected').text();
        var qty = parseInt($('#productQty').val()) || 0;
        var price = parseFloat($('#productPrice').val()) || 0;

        if (!productId) { alert('لطفاً محصول را انتخاب کنید'); return; }
        if (qty <= 0) { alert('تعداد باید بیشتر از 0 باشد'); return; }
        if (price < 0) { alert('قیمت نمی‌تواند منفی باشد'); return; }

        factorItems.push({
            salableId: parseInt(productId),
            packId: null,
            parentId: null,
            qty: qty,
            price: price,
            productName: productName,
            isPack: false
        });

        renderItems();
        // Reset
        $('#productSelect').val('');
        $('#productQty').val(1);
        $('#productPrice').val('');
    }

    function addPackItem() {
        var packId = $('#packSelect').val();
        var packName = $('#packSelect option:selected').text();
        var qty = parseInt($('#packQty').val()) || 0;

        if (!packId) { alert('لطفاً بسته را انتخاب کنید'); return; }
        if (qty <= 0) { alert('تعداد باید بیشتر از 0 باشد'); return; }

        // Find pack items
        var pack = packData.find(p => p.id == packId);
        if (!pack) return;

        // Add parent item (pack header)
        factorItems.push({
            salableId: null,
            packId: parseInt(packId),
            parentId: null,
            qty: qty,
            price: 0, // Will be calculated from sub-items
            productName: packName,
            isPack: true
        });

        // Add sub-items
        if (pack.items && pack.items.length > 0) {
            pack.items.forEach(function(item) {
                factorItems.push({
                    salableId: item.productId,
                    packId: null,
                    parentId: parseInt(packId),
                    qty: item.qty * qty,
                    price: item.price,
                    productName: item.productName,
                    isPack: false
                });
            });
        }

        renderItems();
        // Reset
        $('#packSelect').val('');
        $('#packQty').val(1);
    }

    function removeItem(index) {
        var item = factorItems[index];
        // If removing a pack parent, also remove its children
        if (item.isPack && item.packId) {
            factorItems = factorItems.filter(fi => fi.parentId !== item.packId);
        }
        // If removing a pack child, also remove its parent if no more children
        if (item.parentId) {
            var siblings = factorItems.filter(fi => fi.parentId === item.parentId && fi !== item);
            if (siblings.length === 0) {
                factorItems = factorItems.filter(fi => !(fi.isPack && fi.packId === item.parentId));
            }
        }
        factorItems.splice(factorItems.indexOf(item), 1);
        renderItems();
    }

    function renderItems() {
        var tbody = $('#factorItemsBody');
        tbody.empty();

        if (factorItems.length === 0) {
            tbody.append('<tr id="emptyRow"><td colspan="6" class="text-center text-muted py-3">هنوز آیتمی اضافه نشده است</td></tr>');
        } else {
            var total = 0;
            var rowNum = 1;
            factorItems.forEach(function(item, index) {
                var itemTotal = item.price * item.qty;
                total += itemTotal;

                var rowClass = item.isPack ? 'table-active fw-bold' : (item.parentId ? 'table-light' : '');
                var indent = item.parentId ? '<i class="bi bi-arrow-return-left ms-2"></i>' : '';
                var icon = item.isPack ? '<i class="bi bi-box-seam"></i> ' : '<i class="bi bi-box"></i> ';

                tbody.append(
                    '<tr class="' + rowClass + '">' +
                    '<td>' + rowNum + '</td>' +
                    '<td>' + indent + icon + item.productName + '</td>' +
                    '<td>' + item.qty.toLocaleString() + '</td>' +
                    '<td>' + item.price.toLocaleString() + '</td>' +
                    '<td>' + itemTotal.toLocaleString() + '</td>' +
                    '<td><button class="btn btn-sm btn-outline-danger" onclick="removeItem(' + index + ')"><i class="bi bi-trash"></i></button></td>' +
                    '</tr>'
                );
                rowNum++;
            });

            $('#totalAmount').text(total.toLocaleString() + ' ریال');
            $('#summaryTotal').text(total.toLocaleString() + ' ریال');
            $('#summaryFinal').text(total.toLocaleString() + ' ریال');
        }

        var itemCount = factorItems.filter(i => !i.parentId).length;
        $('#itemCount').text(factorItems.length + ' آیتم');
        $('#summaryItems').text(factorItems.length);
    }

    function saveFactor() {
        var personId = parseInt($('#personSelect').val());
        if (!personId) {
            alert('لطفاً مشتری را انتخاب کنید');
            return;
        }

        if (factorItems.length === 0) {
            alert('فاکتور باید حداقل یک آیتم داشته باشد');
            return;
        }

        var data = {
            personId: personId,
            items: factorItems.map(function(item) {
                return {
                    salableId: item.salableId,
                    packId: item.packId,
                    parentId: item.parentId,
                    qty: item.qty,
                    price: item.price,
                    productName: item.productName
                };
            })
        };

        $.ajax({
            url: '/Factor/CreateFactor',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            headers: {
                'X-CSRF-TOKEN': $('input[name="__RequestVerificationToken"]').val()
            },
            success: function(result) {
                if (result.success) {
                    alert(result.message);
                    window.location.href = '/Factor/Details/' + result.factorId;
                } else {
                    alert('خطا: ' + result.message);
                }
            },
            error: function() {
                alert('خطا در ارتباط با سرور');
            }
        });
    }

    function clearAll() {
        if (confirm('آیا از پاک کردن تمام آیتم‌ها مطمئن هستید؟')) {
            factorItems = [];
            renderItems();
            $('#personSelect').val('');
        }
    }
</script>
}
