@{
    ViewData["Title"] = "صدور فاکتور";
    var packs = ViewBag.Packs as dynamic;
}
@Html.AntiForgeryToken()

<div class="page-header">
    <h4><i class="bi bi-receipt-cutoff"></i> صدور فاکتور جدید</h4>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-right"></i> بازگشت
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <!-- Factor Info -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-primary text-white">
                <h6 class="mb-0"><i class="bi bi-info-circle"></i> اطلاعات فاکتور</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">مشتری</label>
                        <select id="personSelect" class="form-select" required>
                            <option value="">جستجوی مشتری...</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">تاریخ</label>
                        <input type="text" class="form-control bg-light" value="@Factors.Web.Models.Entities.PersianDateService.Now" readonly />
                    </div>
                </div>
            </div>
        </div>

        <!-- Add Product/Pack to Factor -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-info text-white">
                <h6 class="mb-0"><i class="bi bi-plus-circle"></i> افزودن آیتم</h6>
            </div>
            <div class="card-body">
                <ul class="nav nav-tabs mb-3" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#productTab" type="button">
                            <i class="bi bi-box"></i> محصول
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#packTab" type="button">
                            <i class="bi bi-box-seam"></i> بسته
                        </button>
                    </li>
                </ul>
                <div class="tab-content">
                    <div class="tab-pane fade show active" id="productTab">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-5">
                                <label class="form-label small">محصول</label>
                                <select id="productSelect" class="form-select form-select-sm">
                                    <option value="">جستجوی محصول...</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small">تعداد</label>
                                <input type="number" id="productQty" class="form-control form-control-sm" min="1" value="1" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">قیمت واحد</label>
                                <input type="number" id="productPrice" class="form-control form-control-sm" min="0" />
                            </div>
                            <div class="col-md-2">
                                <button type="button" class="btn btn-success btn-sm w-100" onclick="addProductItem()">
                                    <i class="bi bi-plus"></i> افزودن
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="packTab">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-5">
                                <label class="form-label small">بسته</label>
                                <select id="packSelect" class="form-select form-select-sm">
                                    <option value="">جستجوی بسته...</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">تعداد</label>
                                <input type="number" id="packQty" class="form-control form-control-sm" min="1" value="1" />
                            </div>
                            <div class="col-md-2">
                                <button type="button" class="btn btn-success btn-sm w-100" onclick="addPackItem()">
                                    <i class="bi bi-plus"></i> افزودن
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Factor Items List -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold"><i class="bi bi-list-ul"></i> آیتم‌های فاکتور</h6>
                <span id="itemCount" class="badge bg-primary">0 آیتم</span>
            </div>
            <div class="card-body" id="factorItemsContainer">
                <div id="emptyState" class="text-center text-muted py-4">
                    <i class="bi bi-inbox" style="font-size:2rem;"></i>
                    <p class="mt-2 mb-0">هنوز آیتمی اضافه نشده است</p>
                </div>
                <div id="factorItemsList"></div>
            </div>
            <div class="card-footer bg-white">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold">جمع کل:</span>
                    <span class="fw-bold text-success fs-5" id="totalAmount">0 ریال</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <!-- Quick Actions -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-success text-white">
                <h6 class="mb-0"><i class="bi bi-lightning"></i> عملیات</h6>
            </div>
            <div class="card-body">
                <button type="button" class="btn btn-success w-100 mb-2 py-2 fw-bold" onclick="saveFactor()">
                    <i class="bi bi-check-circle"></i> ثبت فاکتور
                </button>
                <button type="button" class="btn btn-outline-secondary w-100 mb-2" onclick="clearAll()">
                    <i class="bi bi-arrow-counterclockwise"></i> پاک کردن همه
                </button>
                <a asp-action="Index" class="btn btn-outline-danger w-100">
                    <i class="bi bi-x-circle"></i> انصراف
                </a>
            </div>
        </div>

        <!-- Factor Summary -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="bi bi-calculator"></i> خلاصه فاکتور</h6>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">تعداد آیتم‌ها:</span>
                    <strong id="summaryItems">0</strong>
                </div>
                <hr />
                <div class="d-flex justify-content-between">
                    <span class="fw-bold">مبلغ نهایی:</span>
                    <strong id="summaryFinal" class="text-success fs-5">0 ریال</strong>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let factorItems = [];
    let packData = @Html.Raw(Json.Serialize(packs));
    let packCounter = 0;

    // ---- Select2 Initialization ----
    function initSelect2() {
        // Person select - AJAX search
        $('#personSelect').select2({
            rtl: true,
            placeholder: 'جستجوی مشتری...',
            allowClear: true,
            language: {
                searching: function() { return 'در حال جستجو...'; },
                inputTooShort: function() { return 'حداقل ۱ حرف وارد کنید'; },
                noResults: function() { return 'نتیجه‌ای یافت نشد'; },
                errorLoading: function() { return 'خطا در بارگذاری'; }
            },
            ajax: {
                url: '/Person/Search',
                dataType: 'json',
                delay: 250,
                data: function(params) {
                    return { term: params.term || '' };
                },
                processResults: function(data) {
                    return {
                        results: data.map(function(p) {
                            return { id: p.id, text: p.name + ' (' + p.type + ')' };
                        })
                    };
                },
                cache: true
            },
            minimumInputLength: 0
        });

        // Product select - AJAX search
        $('#productSelect').select2({
            rtl: true,
            placeholder: 'جستجوی محصول...',
            allowClear: true,
            language: {
                searching: function() { return 'در حال جستجو...'; },
                inputTooShort: function() { return 'حداقل ۱ حرف وارد کنید'; },
                noResults: function() { return 'نتیجه‌ای یافت نشد'; },
                errorLoading: function() { return 'خطا در بارگذاری'; }
            },
            ajax: {
                url: '/Product/Search',
                dataType: 'json',
                delay: 250,
                data: function(params) {
                    return { term: params.term || '' };
                },
                processResults: function(data) {
                    return {
                        results: data.map(function(p) {
                            return { id: p.id, text: p.name + ' (' + p.code + ') — ' + p.category };
                        })
                    };
                },
                cache: true
            },
            minimumInputLength: 0
        });

        // Pack select - AJAX search
        $('#packSelect').select2({
            rtl: true,
            placeholder: 'جستجوی بسته...',
            allowClear: true,
            language: {
                searching: function() { return 'در حال جستجو...'; },
                inputTooShort: function() { return 'حداقل ۱ حرف وارد کنید'; },
                noResults: function() { return 'نتیجه‌ای یافت نشد'; },
                errorLoading: function() { return 'خطا در بارگذاری'; }
            },
            ajax: {
                url: '/Pack/Search',
                dataType: 'json',
                delay: 250,
                data: function(params) {
                    return { term: params.term || '' };
                },
                processResults: function(data) {
                    return {
                        results: data.map(function(p) {
                            return { id: p.id, text: p.name + ' (' + p.code + ')' };
                        })
                    };
                },
                cache: true
            },
            minimumInputLength: 0
        });
    }

    // Auto-fill price when product selected
    $('#productSelect').on('select2:select', function(e) {
        var productId = $(this).val();
        if (productId) {
            $.get('/Factor/GetProductCurrentPrice?productId=' + productId, function(data) {
                if (data.price > 0) {
                    $('#productPrice').val(data.price);
                }
            });
        }
    });

    function addProductItem() {
        var productId = $('#productSelect').val();
        var productName = $('#productSelect').select2('data')[0]?.text || '';
        var qty = parseInt($('#productQty').val()) || 0;
        var price = parseFloat($('#productPrice').val()) || 0;

        if (!productId) { alert('لطفاً محصول را انتخاب کنید'); return; }
        if (qty <= 0) { alert('تعداد باید بیشتر از 0 باشد'); return; }
        if (price < 0) { alert('قیمت نمی‌تواند منفی باشد'); return; }

        factorItems.push({
            uid: 'item-' + Date.now(),
            salableId: parseInt(productId),
            packId: null,
            parentId: null,
            qty: qty,
            price: price,
            productName: productName,
            isPack: false
        });

        renderItems();
        $('#productSelect').val(null).trigger('change');
        $('#productQty').val(1);
        $('#productPrice').val('');
    }

    function addPackItem() {
        var packId = $('#packSelect').val();
        var packName = $('#packSelect').select2('data')[0]?.text || '';
        var qty = parseInt($('#packQty').val()) || 0;

        if (!packId) { alert('لطفاً بسته را انتخاب کنید'); return; }
        if (qty <= 0) { alert('تعداد باید بیشتر از 0 باشد'); return; }

        var pack = packData.find(p => p.id == packId);
        if (!pack) return;

        var packUid = 'pack-' + (++packCounter);

        var packTotalPrice = 0;
        if (pack.items && pack.items.length > 0) {
            pack.items.forEach(function(item) {
                packTotalPrice += item.price * item.qty * qty;
            });
        }

        factorItems.push({
            uid: packUid,
            salableId: null,
            packId: parseInt(packId),
            parentId: null,
            qty: qty,
            price: packTotalPrice / qty,
            productName: packName,
            isPack: true,
            childCount: pack.items ? pack.items.length : 0
        });

        if (pack.items && pack.items.length > 0) {
            pack.items.forEach(function(item) {
                factorItems.push({
                    uid: 'sub-' + Date.now() + '-' + Math.random().toString(36).substr(2, 5),
                    salableId: item.productId,
                    packId: null,
                    parentId: packUid,
                    qty: item.qty * qty,
                    price: item.price,
                    productName: item.productName,
                    isPack: false
                });
            });
        }

        renderItems();
        $('#packSelect').val(null).trigger('change');
        $('#packQty').val(1);
    }

    function removeItem(uid) {
        var item = factorItems.find(i => i.uid === uid);
        if (!item) return;

        if (item.isPack && item.uid) {
            factorItems = factorItems.filter(fi => fi.parentId !== item.uid);
        }
        if (item.parentId) {
            factorItems = factorItems.filter(fi => fi.uid !== item.uid);
            var siblings = factorItems.filter(fi => fi.parentId === item.parentId);
            if (siblings.length === 0) {
                factorItems = factorItems.filter(fi => fi.uid !== item.parentId);
            }
        } else {
            factorItems = factorItems.filter(fi => fi.uid !== item.uid);
        }

        renderItems();
    }

    function renderItems() {
        var container = $('#factorItemsList');
        container.empty();

        if (factorItems.length === 0) {
            $('#emptyState').show();
            $('#totalAmount').text('0 ریال');
            $('#summaryItems').text('0');
            $('#summaryFinal').text('0 ریال');
            $('#itemCount').text('0 آیتم');
            return;
        }

        $('#emptyState').hide();

        var total = 0;
        var itemNum = 1;

        factorItems.forEach(function(item) {
            var itemTotal = item.price * item.qty;
            total += itemTotal;

            if (item.isPack) {
                var childItems = factorItems.filter(fi => fi.parentId === item.uid);
                var collapseId = 'collapse-' + item.uid;

                var html = '<div class="pack-item mb-2">';
                html += '<div class="d-flex align-items-center justify-content-between pack-header px-3 py-2 rounded-2" style="background:#eef0ff;cursor:pointer;" data-bs-toggle="collapse" data-bs-target="#' + collapseId + '">';
                html += '<div class="d-flex align-items-center">';
                html += '<span class="badge bg-primary me-2" style="min-width:28px">' + itemNum + '</span>';
                html += '<i class="bi bi-box-seam text-primary me-2"></i>';
                html += '<strong>' + item.productName + '</strong>';
                html += '<span class="text-muted small me-3"> × ' + item.qty.toLocaleString() + '</span>';
                html += '<i class="bi bi-chevron-left small text-muted collapse-icon-' + item.uid + '"></i>';
                html += '</div>';
                html += '<div class="d-flex align-items-center">';
                html += '<span class="text-success fw-bold me-3">' + itemTotal.toLocaleString() + ' ریال</span>';
                html += '<button class="btn btn-sm btn-outline-danger border-0" onclick="event.stopPropagation();removeItem(\'' + item.uid + '\')"><i class="bi bi-trash"></i></button>';
                html += '</div>';
                html += '</div>';

                html += '<div class="collapse" id="' + collapseId + '">';
                html += '<div class="ps-4 pe-3 py-1">';
                childItems.forEach(function(child) {
                    var childTotal = child.price * child.qty;
                    html += '<div class="d-flex align-items-center justify-content-between py-2 border-bottom" style="border-color:#edf2f7 !important;">';
                    html += '<div class="d-flex align-items-center">';
                    html += '<i class="bi bi-arrow-return-left text-muted me-2"></i>';
                    html += '<i class="bi bi-box text-secondary me-2" style="font-size:0.85rem;"></i>';
                    html += '<span class="text-muted">' + child.productName + '</span>';
                    html += '</div>';
                    html += '<div class="d-flex align-items-center gap-3 small text-muted">';
                    html += '<span>' + child.qty.toLocaleString() + ' عدد</span>';
                    html += '<span>' + child.price.toLocaleString() + ' ریال</span>';
                    html += '<span class="text-dark">' + childTotal.toLocaleString() + ' ریال</span>';
                    html += '</div>';
                    html += '</div>';
                });
                html += '</div></div>';
                html += '</div>';

                container.append(html);
                (function(uid) {
                    var el = document.getElementById('collapse-' + uid);
                    if (el) {
                        el.addEventListener('show.bs.collapse', function() {
                            $('.collapse-icon-' + uid).removeClass('bi-chevron-left').addClass('bi-chevron-down');
                        });
                        el.addEventListener('hide.bs.collapse', function() {
                            $('.collapse-icon-' + uid).removeClass('bi-chevron-down').addClass('bi-chevron-left');
                        });
                    }
                })(item.uid);
                itemNum++;

            } else if (!item.parentId) {
                var html = '<div class="d-flex align-items-center justify-content-between px-3 py-2 rounded-2 mb-1" style="background:#f8fafc;">';
                html += '<div class="d-flex align-items-center">';
                html += '<span class="badge bg-light text-dark me-2" style="min-width:28px">' + itemNum + '</span>';
                html += '<i class="bi bi-box text-secondary me-2"></i>';
                html += '<span>' + item.productName + '</span>';
                html += '<span class="text-muted small me-3"> × ' + item.qty.toLocaleString() + '</span>';
                html += '</div>';
                html += '<div class="d-flex align-items-center">';
                html += '<span class="fw-bold me-3">' + itemTotal.toLocaleString() + ' ریال</span>';
                html += '<span class="text-muted small me-3">' + item.price.toLocaleString() + ' ریال/واحد</span>';
                html += '<button class="btn btn-sm btn-outline-danger border-0" onclick="removeItem(\'' + item.uid + '\')"><i class="bi bi-trash"></i></button>';
                html += '</div>';
                html += '</div>';

                container.append(html);
                itemNum++;
            }
        });

        var mainItems = factorItems.filter(i => !i.parentId);
        $('#itemCount').text(mainItems.length + ' آیتم');
        $('#summaryItems').text(factorItems.length.toString());
        $('#totalAmount').text(total.toLocaleString() + ' ریال');
        $('#summaryFinal').text(total.toLocaleString() + ' ریال');
    }

    function saveFactor() {
        var personId = parseInt($('#personSelect').val());
        if (!personId) { alert('لطفاً مشتری را انتخاب کنید'); return; }
        if (factorItems.length === 0) { alert('فاکتور باید حداقل یک آیتم داشته باشد'); return; }

        var data = {
            personId: personId,
            items: factorItems.map(function(item) {
                return {
                    salableId: item.salableId,
                    packId: item.packId,
                    parentId: item.parentId ? item.parentId.replace('pack-', '') : null,
                    qty: item.qty,
                    price: item.price,
                    productName: item.productName
                };
            })
        };

        data.items.forEach(function(item) {
            if (item.parentId) {
                var parentPack = factorItems.find(fi => fi.uid === item.parentId);
                item.parentId = parentPack ? parentPack.packId : null;
            }
        });

        $.ajax({
            url: '/Factor/CreateFactor',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            headers: {
                'X-CSRF-TOKEN': $('input[name="__RequestVerificationToken"]').val()
            },
            success: function(result) {
                if (result.success) {
                    window.location.href = '/Factor/Details/' + result.factorId;
                } else {
                    alert('خطا: ' + result.message);
                }
            },
            error: function() {
                alert('خطا در ارتباط با سرور');
            }
        });
    }

    function clearAll() {
        if (confirm('آیا از پاک کردن تمام آیتم‌ها مطمئن هستید؟')) {
            factorItems = [];
            packCounter = 0;
            renderItems();
            $('#personSelect').val(null).trigger('change');
        }
    }

    // Initialize Select2 on page load
    $(document).ready(function() {
        initSelect2();
    });
</script>
}
