@model Factors.Web.Models.ViewModels.FactorListViewModel
@using Factors.Web.Models.ViewModels
@{
    ViewData["Title"] = "فاکتورها";
    var printTemplates = ViewBag.PrintTemplates as List<PrintTemplateOption> ?? new List<PrintTemplateOption>();
    var hasMultipleTemplates = printTemplates.Count > 1;
}

<div class="page-header">
    <h4><i class="bi bi-receipt-cutoff"></i> فاکتورها</h4>
    <div class="d-flex gap-2">
        <a asp-controller="ReportBuilder" asp-action="Index" class="btn btn-success btn-sm">
            <i class="bi bi-magic"></i> مرکز گزارش‌سازی
        </a>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg"></i> فاکتور جدید
        </a>
    </div>
</div>

<!-- Search & Filter -->
<form asp-action="Index" method="get" class="mb-3">
    <div class="search-bar">
        <div class="row g-2 align-items-center">
            <div class="col-md-3">
                <input type="text" name="search" value="@Model.SearchTerm" class="form-control form-control-sm" placeholder="جستجو نام مشتری یا شماره..." />
            </div>
            <div class="col-md-3">
                <input type="text" name="fromDateJalali" value="@Model.FromDateJalali" class="form-control form-control-sm persian-datepicker" placeholder="از تاریخ شمسی" autocomplete="off" />
            </div>
            <div class="col-md-3">
                <input type="text" name="toDateJalali" value="@Model.ToDateJalali" class="form-control form-control-sm persian-datepicker" placeholder="تا تاریخ شمسی" autocomplete="off" />
            </div>
            <div class="col-md-3">
                <button class="btn btn-outline-primary btn-sm w-100" type="submit"><i class="bi bi-search"></i> جستجو</button>
            </div>
        </div>
    </div>
</form>

<!-- Factors Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header-compact">
        <span class="icon-badge icon-badge-blue"><i class="bi bi-table"></i></span>
        <span class="header-title">لیست فاکتورها</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 table-compact">
                <thead>
                    <tr>
                        <th style="width:60px">شماره</th>
                        <th>مشتری</th>
                        <th>تعداد آیتم</th>
                        <th>مبلغ کل (ریال)</th>
                        <th>تاریخ</th>
                        <th style="width:200px">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Factors.Any())
                    {
                        foreach (var item in Model.Factors)
                        {
                            <tr>
                                <td><strong>@item.Id</strong></td>
                                <td>@item.PersonName</td>
                                <td><span class="badge bg-info">@item.TotalItems</span></td>
                                <td><span class="text-success fw-bold">@item.TotalAmount.ToString("N0")</span></td>
                                <td><small class="text-muted">@item.PersianCreateDate</small></td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="مشاهده و گزارش">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (hasMultipleTemplates)
                                    {
                                        <div class="dropdown d-inline-block">
                                            <button class="btn btn-sm btn-outline-success dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="چاپ فاکتور">
                                                <i class="bi bi-printer"></i>
                                            </button>
                                            <ul class="dropdown-menu">
                                                @foreach (var t in printTemplates)
                                                {
                                                    <li>
                                                        <a class="dropdown-item" href="@Url.Action("Print", "Factor", new { id = item.Id, templateId = t.Id })" target="_blank">
                                                            @if (t.Id == 0)
                                                            {
                                                                <i class="bi bi-file-pdf text-danger"></i>
                                                            }
                                                            else
                                                            {
                                                                <i class="bi bi-file-earmark-word text-primary"></i>
                                                            }
                                                            @t.Name
                                                        </a>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    }
                                    else
                                    {
                                        <a asp-action="Print" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success" title="چاپ" target="_blank">
                                            <i class="bi bi-printer"></i>
                                        </a>
                                    }
                                    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                    {
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('آیا از حذف این فاکتور مطمئن هستید؟')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="حذف"><i class="bi bi-trash"></i></button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4">فاکتوری یافت نشد</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
