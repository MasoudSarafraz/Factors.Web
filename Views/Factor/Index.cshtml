@model Factors.Web.Models.ViewModels.FactorListViewModel
@{
    ViewData["Title"] = "فاکتورها";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0"><i class="bi bi-receipt-cutoff"></i> فاکتورها</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> فاکتور جدید
    </a>
</div>

<!-- Search & Filter -->
<form asp-action="Index" method="get" class="mb-3">
    <div class="row g-2">
        <div class="col-md-3">
            <input type="text" name="search" value="@Model.SearchTerm" class="form-control" placeholder="جستجو..." />
        </div>
        <div class="col-md-3">
            <input type="date" name="fromDate" value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" class="form-control" placeholder="از تاریخ" />
        </div>
        <div class="col-md-3">
            <input type="date" name="toDate" value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" class="form-control" placeholder="تا تاریخ" />
        </div>
        <div class="col-md-3">
            <button class="btn btn-outline-primary w-100" type="submit"><i class="bi bi-search"></i> جستجو</button>
        </div>
    </div>
</form>

<!-- Factors Table -->
<div class="card border-0 shadow-sm rounded-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px">شماره</th>
                        <th>مشتری</th>
                        <th>تعداد آیتم</th>
                        <th>مبلغ کل (ریال)</th>
                        <th>تاریخ</th>
                        <th style="width:200px">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Factors.Any())
                    {
                        foreach (var item in Model.Factors)
                        {
                            <tr>
                                <td><strong>@item.Id</strong></td>
                                <td>@item.PersonName</td>
                                <td><span class="badge bg-info">@item.TotalItems</span></td>
                                <td><span class="text-success fw-bold">@item.TotalAmount.ToString("N0")</span></td>
                                <td>@item.PersianCreateDate</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="مشاهده">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Print" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success" title="چاپ PDF" target="_blank">
                                        <i class="bi bi-printer"></i>
                                    </a>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                    {
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('آیا از حذف این فاکتور مطمئن هستید؟')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="حذف"><i class="bi bi-trash"></i></button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4">فاکتوری یافت نشد</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
