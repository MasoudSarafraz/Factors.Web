@model Factors.Web.Models.ViewModels.PackListViewModel
@{
    ViewData["Title"] = "بسته‌ها";
}

<div class="page-header">
    <h4><i class="bi bi-box-seam"></i> بسته‌ها</h4>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">
        <i class="bi bi-plus-lg"></i> بسته جدید
    </button>
</div>

<!-- Search -->
<form asp-action="Index" method="get" class="mb-3">
    <div class="row g-2">
        <div class="col-md-6">
            <div class="input-group">
                <input type="text" name="search" value="@Model.SearchTerm" class="form-control" placeholder="جستجو در بسته‌ها..." />
                <button class="btn btn-outline-primary" type="submit"><i class="bi bi-search"></i></button>
            </div>
        </div>
    </div>
</form>

<!-- Packs -->
@foreach (var pack in Model.Packs)
{
    <div class="card border-0 shadow-sm rounded-3 mb-3">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <div>
                <h6 class="mb-0 fw-bold">@pack.PackName</h6>
                <small class="text-muted">کد: @pack.PackCode | تاریخ: @pack.PersianCreateDate</small>
            </div>
            <div>
                <span class="badge bg-success fs-6">@pack.TotalPrice.ToString("N0") ریال</span>
                <button class="btn btn-sm btn-outline-info ms-1" onclick="addItem(@pack.Id, '@pack.PackName')" title="افزودن آیتم">
                    <i class="bi bi-plus"></i> آیتم
                </button>
                <button class="btn btn-sm btn-outline-warning" onclick="editPack(@pack.Id)" title="ویرایش">
                    <i class="bi bi-pencil"></i>
                </button>
                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                {
                    <form asp-action="Delete" asp-route-id="@pack.Id" method="post" class="d-inline" onsubmit="return confirm('آیا از حذف این بسته مطمئن هستید؟')">
                        <button type="submit" class="btn btn-sm btn-outline-danger" title="حذف"><i class="bi bi-trash"></i></button>
                    </form>
                }
            </div>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th>محصول</th>
                        <th>تعداد</th>
                        <th>قیمت واحد</th>
                        <th>جمع</th>
                        <th style="width:60px">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (pack.Items.Any())
                    {
                        foreach (var item in pack.Items)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td>@item.Qty</td>
                                <td>@item.Price.ToString("N0") ریال</td>
                                <td>@item.TotalPrice.ToString("N0") ریال</td>
                                <td>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                    {
                                        <form asp-action="DeleteItem" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('آیا از حذف این آیتم مطمئن هستید؟')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="حذف"><i class="bi bi-trash"></i></button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center text-muted py-2">آیتمی تعریف نشده</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (!Model.Packs.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-box-seam" style="font-size:3rem;"></i>
        <p class="mt-2">بسته‌ای یافت نشد</p>
    </div>
}

<!-- Create Pack Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-plus-circle"></i> بسته جدید</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">نام بسته</label>
                        <input type="text" name="PackName" class="form-control" required maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">کد بسته</label>
                        <input type="text" name="PackCode" class="form-control" required maxlength="50" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">انصراف</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> ثبت</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Pack Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Edit" method="post">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title"><i class="bi bi-pencil"></i> ویرایش بسته</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="Id" id="editId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">نام بسته</label>
                        <input type="text" name="PackName" id="editPackName" class="form-control" required maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">کد بسته</label>
                        <input type="text" name="PackCode" id="editPackCode" class="form-control" required maxlength="50" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">انصراف</button>
                    <button type="submit" class="btn btn-warning"><i class="bi bi-check-lg"></i> ویرایش</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Item Modal -->
<div class="modal fade" id="itemModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="AddItem" method="post">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title"><i class="bi bi-plus"></i> افزودن آیتم به بسته - <span id="itemPackName"></span></h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="PackId" id="itemPackId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">محصول</label>
                        <select name="ProductId" id="itemProductId" class="form-select" required>
                            <option value="">انتخاب کنید</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">تعداد</label>
                        <input type="number" name="Qty" class="form-control" required min="1" value="1" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">قیمت (ریال)</label>
                        <input type="number" name="Price" class="form-control" required min="0" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">انصراف</button>
                    <button type="submit" class="btn btn-info text-white"><i class="bi bi-check-lg"></i> افزودن</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function editPack(id) {
        $.get('/Pack/GetById/' + id, function(data) {
            $('#editId').val(data.id);
            $('#editPackName').val(data.packName);
            $('#editPackCode').val(data.packCode);
            new bootstrap.Modal($('#editModal')).show();
        });
    }

    function addItem(packId, packName) {
        $('#itemPackId').val(packId);
        $('#itemPackName').text(packName);
        // Load products
        $.get('/Product/Search?term=', function(data) {
            var select = $('#itemProductId');
            select.empty().append('<option value="">انتخاب کنید</option>');
            data.forEach(function(p) {
                select.append('<option value="' + p.id + '">' + p.name + ' (' + p.code + ')</option>');
            });
            new bootstrap.Modal($('#itemModal')).show();
        });
    }
</script>
}
